          "default": null,
          "title": "Ref"
        },
        "severity": {
          "pattern": "^(info|warning|error)$",
          "title": "Severity",
          "type": "string"
        }
      },
      "required": [
        "code",
        "severity",
        "detail"
      ],
      "title": "ProposalAdapterCheckIssue",
      "type": "object"
    },
