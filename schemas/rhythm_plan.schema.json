{
  "$defs": {
    "RhythmAuditDomain": {
      "additionalProperties": false,
      "properties": {
        "domain_id": {
          "minLength": 1,
          "title": "Domain Id",
          "type": "string"
        },
        "issues": {
          "items": {
            "$ref": "#/$defs/RhythmIssue"
          },
          "title": "Issues",
          "type": "array"
        },
        "metrics": {
          "items": {
            "$ref": "#/$defs/RhythmProfileMetric"
          },
          "title": "Metrics",
          "type": "array"
        },
        "status": {
          "pattern": "^(passed|warning|blocked|unavailable)$",
          "title": "Status",
          "type": "string"
        },
        "summary": {
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        }
      },
      "required": [
        "domain_id",
        "status",
        "summary"
      ],
      "title": "RhythmAuditDomain",
      "type": "object"
    },
    "RhythmIntent": {
      "additionalProperties": false,
      "properties": {
        "ending_style": {
          "pattern": "^(clean_stop|fade_out|open_loop)$",
          "title": "Ending Style",
          "type": "string"
        },
        "intent_id": {
          "minLength": 1,
          "title": "Intent Id",
          "type": "string"
        },
        "mode": {
          "pattern": "^(speech_first|music_first|balanced)$",
          "title": "Mode",
          "type": "string"
        },
        "model_call_performed_by_cli": {
          "default": false,
          "title": "Model Call Performed By Cli",
          "type": "boolean"
        },
        "network_performed": {
          "default": false,
          "title": "Network Performed",
          "type": "boolean"
        },
        "notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Notes"
        },
        "pacing": {
          "pattern": "^(calm|medium|fast)$",
          "title": "Pacing",
          "type": "string"
        },
        "text_density": {
          "pattern": "^(none|low|medium|high)$",
          "title": "Text Density",
          "type": "string"
        },
        "transition_style": {
          "pattern": "^(minimal|smooth|energetic)$",
          "title": "Transition Style",
          "type": "string"
        }
      },
      "required": [
        "intent_id",
        "mode",
        "pacing",
        "text_density",
        "transition_style",
        "ending_style"
      ],
      "title": "RhythmIntent",
      "type": "object"
    },
    "RhythmIssue": {
      "additionalProperties": false,
      "properties": {
        "detail": {
          "minLength": 1,
          "title": "Detail",
          "type": "string"
        },
        "domain": {
          "pattern": "^(timeline|bgm|compatibility|intent|cut_cue|transition|text|ducking_silence|ending|agent_candidate)$",
          "title": "Domain",
          "type": "string"
        },
        "issue_id": {
          "minLength": 1,
          "title": "Issue Id",
          "type": "string"
        },
        "next_action": {
          "minLength": 1,
          "title": "Next Action",
          "type": "string"
        },
        "severity": {
          "pattern": "^(info|warning|error)$",
          "title": "Severity",
          "type": "string"
        }
      },
      "required": [
        "issue_id",
        "domain",
        "severity",
        "detail",
        "next_action"
      ],
      "title": "RhythmIssue",
      "type": "object"
    },
    "RhythmProfileMetric": {
      "additionalProperties": false,
      "properties": {
        "detail": {
          "minLength": 1,
          "title": "Detail",
          "type": "string"
        },
        "label": {
          "minLength": 1,
          "title": "Label",
          "type": "string"
        },
        "metric_id": {
          "minLength": 1,
          "title": "Metric Id",
          "type": "string"
        },
        "status": {
          "pattern": "^(available|unavailable|warning)$",
          "title": "Status",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "string"
            },
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        }
      },
      "required": [
        "metric_id",
        "label",
        "status",
        "detail"
      ],
      "title": "RhythmProfileMetric",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "agent_candidate_audit": {
      "anyOf": [
        {
          "$ref": "#/$defs/RhythmAuditDomain"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "automatic_music_selection": {
      "default": false,
      "title": "Automatic Music Selection",
      "type": "boolean"
    },
    "bgm_analysis_fingerprint": {
      "anyOf": [
        {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Bgm Analysis Fingerprint"
    },
    "bgm_fit_fingerprint": {
      "anyOf": [
        {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Bgm Fit Fingerprint"
    },
    "bgm_fit_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Bgm Fit Id"
    },
    "bgm_profile": {
      "$ref": "#/$defs/RhythmAuditDomain"
    },
    "bgm_rhythm_intelligence_fingerprint": {
      "anyOf": [
        {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Bgm Rhythm Intelligence Fingerprint"
    },
    "compatibility_audit": {
      "$ref": "#/$defs/RhythmAuditDomain"
    },
    "cut_cue_audit": {
      "$ref": "#/$defs/RhythmAuditDomain"
    },
    "ducking_silence_audit": {
      "$ref": "#/$defs/RhythmAuditDomain"
    },
    "edit_points_moved": {
      "default": false,
      "title": "Edit Points Moved",
      "type": "boolean"
    },
    "ending_audit": {
      "$ref": "#/$defs/RhythmAuditDomain"
    },
    "error_count": {
      "minimum": 0,
      "title": "Error Count",
      "type": "integer"
    },
    "intent": {
      "$ref": "#/$defs/RhythmIntent"
    },
    "intent_audit": {
      "$ref": "#/$defs/RhythmAuditDomain"
    },
    "issue_count": {
      "minimum": 0,
      "title": "Issue Count",
      "type": "integer"
    },
    "media_rendered": {
      "default": false,
      "title": "Media Rendered",
      "type": "boolean"
    },
    "model_call_performed_by_cli": {
      "default": false,
      "title": "Model Call Performed By Cli",
      "type": "boolean"
    },
    "network_performed": {
      "default": false,
      "title": "Network Performed",
      "type": "boolean"
    },
    "project_id": {
      "minLength": 1,
      "title": "Project Id",
      "type": "string"
    },
    "rhythm_plan_id": {
      "minLength": 1,
      "title": "Rhythm Plan Id",
      "type": "string"
    },
    "schema_version": {
      "default": "0.3",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "pattern": "^(passed|warning|blocked)$",
      "title": "Status",
      "type": "string"
    },
    "text_audit": {
      "$ref": "#/$defs/RhythmAuditDomain"
    },
    "timeline_fingerprint": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Timeline Fingerprint",
      "type": "string"
    },
    "timeline_id": {
      "minLength": 1,
      "title": "Timeline Id",
      "type": "string"
    },
    "timeline_profile": {
      "$ref": "#/$defs/RhythmAuditDomain"
    },
    "transition_audit": {
      "$ref": "#/$defs/RhythmAuditDomain"
    },
    "warning_count": {
      "minimum": 0,
      "title": "Warning Count",
      "type": "integer"
    }
  },
  "required": [
    "rhythm_plan_id",
    "project_id",
    "timeline_id",
    "timeline_fingerprint",
    "intent",
    "timeline_profile",
    "bgm_profile",
    "compatibility_audit",
    "intent_audit",
    "cut_cue_audit",
    "transition_audit",
    "text_audit",
    "ducking_silence_audit",
    "ending_audit",
    "issue_count",
    "warning_count",
    "error_count",
    "status"
  ],
  "title": "RhythmPlan",
  "type": "object"
}
