{
  "$defs": {
    "ClipAudioEnergy": {
      "additionalProperties": false,
      "properties": {
        "dbfs": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dbfs"
        },
        "detail": {
          "minLength": 1,
          "title": "Detail",
          "type": "string"
        },
        "method": {
          "minLength": 1,
          "title": "Method",
          "type": "string"
        },
        "rms": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rms"
        },
        "score": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Score",
          "type": "number"
        },
        "status": {
          "pattern": "^(available|missing|not_applicable|failed)$",
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "status",
        "score",
        "method",
        "detail"
      ],
      "title": "ClipAudioEnergy",
      "type": "object"
    },
    "ClipScoreComponent": {
      "additionalProperties": false,
      "properties": {
        "detail": {
          "minLength": 1,
          "title": "Detail",
          "type": "string"
        },
        "score": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Score",
          "type": "number"
        },
        "status": {
          "pattern": "^(available|missing|not_applicable|failed)$",
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "status",
        "score",
        "detail"
      ],
      "title": "ClipScoreComponent",
      "type": "object"
    },
    "EvidenceRef": {
      "additionalProperties": false,
      "properties": {
        "ref": {
          "minLength": 1,
          "title": "Ref",
          "type": "string"
        },
        "type": {
          "minLength": 1,
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "type",
        "ref"
      ],
      "title": "EvidenceRef",
      "type": "object"
    },
    "MediaKind": {
      "enum": [
        "video",
        "audio"
      ],
      "title": "MediaKind",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "analysis_confidence_score": {
      "$ref": "#/$defs/ClipScoreComponent"
    },
    "analysis_refs": {
      "items": {
        "type": "string"
      },
      "title": "Analysis Refs",
      "type": "array"
    },
    "audio_energy": {
      "$ref": "#/$defs/ClipAudioEnergy"
    },
    "automatic_bgm_fit": {
      "default": false,
      "title": "Automatic Bgm Fit",
      "type": "boolean"
    },
    "automatic_music_selection": {
      "default": false,
      "title": "Automatic Music Selection",
      "type": "boolean"
    },
    "clip_fingerprint": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Clip Fingerprint",
      "type": "string"
    },
    "clip_id": {
      "minLength": 1,
      "title": "Clip Id",
      "type": "string"
    },
    "clip_score_id": {
      "minLength": 1,
      "title": "Clip Score Id",
      "type": "string"
    },
    "commands_executed": {
      "default": false,
      "title": "Commands Executed",
      "type": "boolean"
    },
    "duration_fit_score": {
      "$ref": "#/$defs/ClipScoreComponent"
    },
    "duration_seconds": {
      "exclusiveMinimum": 0,
      "title": "Duration Seconds",
      "type": "number"
    },
    "edit_points_moved": {
      "default": false,
      "title": "Edit Points Moved",
      "type": "boolean"
    },
    "end_seconds": {
      "exclusiveMinimum": 0,
      "title": "End Seconds",
      "type": "number"
    },
    "evidence": {
      "items": {
        "$ref": "#/$defs/EvidenceRef"
      },
      "title": "Evidence",
      "type": "array"
    },
    "evidence_level": {
      "pattern": "^(clips_only|analysis_available|transcript_available|keyframe_available|multi_modal)$",
      "title": "Evidence Level",
      "type": "string"
    },
    "image_generation_or_editing_used": {
      "default": false,
      "title": "Image Generation Or Editing Used",
      "type": "boolean"
    },
    "keep_recommendation": {
      "pattern": "^(keep|consider|review|drop)$",
      "title": "Keep Recommendation",
      "type": "string"
    },
    "keyframe_cluster_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Keyframe Cluster Id"
    },
    "keyframe_coverage_score": {
      "$ref": "#/$defs/ClipScoreComponent"
    },
    "keyframe_refs": {
      "items": {
        "type": "string"
      },
      "title": "Keyframe Refs",
      "type": "array"
    },
    "media_kind": {
      "$ref": "#/$defs/MediaKind"
    },
    "media_rendered": {
      "default": false,
      "title": "Media Rendered",
      "type": "boolean"
    },
    "model_call_performed_by_cli": {
      "default": false,
      "title": "Model Call Performed By Cli",
      "type": "boolean"
    },
    "network_performed": {
      "default": false,
      "title": "Network Performed",
      "type": "boolean"
    },
    "overall_score": {
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Overall Score",
      "type": "number"
    },
    "project_id": {
      "minLength": 1,
      "title": "Project Id",
      "type": "string"
    },
    "reasons": {
      "items": {
        "type": "string"
      },
      "title": "Reasons",
      "type": "array"
    },
    "schema_version": {
      "default": "0.3",
      "title": "Schema Version",
      "type": "string"
    },
    "scoring_fingerprint": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Scoring Fingerprint",
      "type": "string"
    },
    "selection_tier": {
      "pattern": "^(hero|support|context|review|drop)$",
      "title": "Selection Tier",
      "type": "string"
    },
    "source_content_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Source Content Hash",
      "type": "string"
    },
    "source_id": {
      "minLength": 1,
      "title": "Source Id",
      "type": "string"
    },
    "source_location": {
      "minLength": 1,
      "title": "Source Location",
      "type": "string"
    },
    "source_risk_penalty": {
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Source Risk Penalty",
      "type": "number"
    },
    "speech_score": {
      "$ref": "#/$defs/ClipScoreComponent"
    },
    "start_seconds": {
      "minimum": 0,
      "title": "Start Seconds",
      "type": "number"
    },
    "timeline_mutated": {
      "default": false,
      "title": "Timeline Mutated",
      "type": "boolean"
    },
    "transcript_density_score": {
      "$ref": "#/$defs/ClipScoreComponent"
    },
    "transcript_refs": {
      "items": {
        "type": "string"
      },
      "title": "Transcript Refs",
      "type": "array"
    },
    "visual_change_score": {
      "$ref": "#/$defs/ClipScoreComponent"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "clip_score_id",
    "project_id",
    "clip_id",
    "source_id",
    "source_location",
    "source_content_hash",
    "clip_fingerprint",
    "scoring_fingerprint",
    "media_kind",
    "start_seconds",
    "end_seconds",
    "duration_seconds",
    "evidence_level",
    "speech_score",
    "transcript_density_score",
    "audio_energy",
    "visual_change_score",
    "keyframe_coverage_score",
    "analysis_confidence_score",
    "duration_fit_score",
    "source_risk_penalty",
    "overall_score",
    "selection_tier",
    "keep_recommendation"
  ],
  "title": "ClipScoreRecord",
  "type": "object"
}
