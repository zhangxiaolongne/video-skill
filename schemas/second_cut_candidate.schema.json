{
  "$defs": {
    "SecondCutAction": {
      "additionalProperties": false,
      "properties": {
        "action_id": {
          "pattern": "^second_cut_action_[0-9]{2}$",
          "title": "Action Id",
          "type": "string"
        },
        "applied": {
          "default": false,
          "title": "Applied",
          "type": "boolean"
        },
        "domain": {
          "pattern": "^(selection|structure|trim|reframe|source_audio|bgm|text|transition|pause|ending|verification)$",
          "title": "Domain",
          "type": "string"
        },
        "downstream_impacts": {
          "items": {
            "type": "string"
          },
          "title": "Downstream Impacts",
          "type": "array"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Evidence Refs",
          "type": "array"
        },
        "execution_status": {
          "pattern": "^(deterministic|manual_boundary_required|blocked)$",
          "title": "Execution Status",
          "type": "string"
        },
        "expected_effect": {
          "minLength": 1,
          "title": "Expected Effect",
          "type": "string"
        },
        "operation": {
          "minLength": 1,
          "title": "Operation",
          "type": "string"
        },
        "order": {
          "minimum": 1,
          "title": "Order",
          "type": "integer"
        },
        "owns_issue_ids": {
          "items": {
            "type": "string"
          },
          "title": "Owns Issue Ids",
          "type": "array"
        },
        "prerequisites": {
          "items": {
            "type": "string"
          },
          "title": "Prerequisites",
          "type": "array"
        },
        "rationale": {
          "minLength": 1,
          "title": "Rationale",
          "type": "string"
        },
        "reframe_candidate_ids": {
          "items": {
            "type": "string"
          },
          "title": "Reframe Candidate Ids",
          "type": "array"
        },
        "requested_duration_seconds": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Requested Duration Seconds"
        },
        "source_range": {
          "anyOf": [
            {
              "items": {
                "type": "number"
              },
              "maxItems": 2,
              "minItems": 2,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Range"
        },
        "target_segment_ids": {
          "items": {
            "type": "string"
          },
          "title": "Target Segment Ids",
          "type": "array"
        }
      },
      "required": [
        "action_id",
        "order",
        "domain",
        "operation",
        "execution_status",
        "evidence_refs",
        "rationale",
        "expected_effect"
      ],
      "title": "SecondCutAction",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "acceptance_requirements": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "title": "Acceptance Requirements",
      "type": "array"
    },
    "action_count": {
      "minimum": 1,
      "title": "Action Count",
      "type": "integer"
    },
    "actions": {
      "items": {
        "$ref": "#/$defs/SecondCutAction"
      },
      "minItems": 1,
      "title": "Actions",
      "type": "array"
    },
    "aesthetic_baseline_fingerprint": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Aesthetic Baseline Fingerprint",
      "type": "string"
    },
    "aesthetic_baseline_id": {
      "minLength": 1,
      "title": "Aesthetic Baseline Id",
      "type": "string"
    },
    "aesthetic_baseline_ref": {
      "minLength": 1,
      "title": "Aesthetic Baseline Ref",
      "type": "string"
    },
    "automatic_bgm_fit": {
      "default": false,
      "title": "Automatic Bgm Fit",
      "type": "boolean"
    },
    "baseline_timeline_fingerprint": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Baseline Timeline Fingerprint",
      "type": "string"
    },
    "baseline_timeline_id": {
      "minLength": 1,
      "title": "Baseline Timeline Id",
      "type": "string"
    },
    "baseline_timeline_ref": {
      "minLength": 1,
      "title": "Baseline Timeline Ref",
      "type": "string"
    },
    "blocked_action_count": {
      "minimum": 0,
      "title": "Blocked Action Count",
      "type": "integer"
    },
    "candidate_id": {
      "minLength": 1,
      "title": "Candidate Id",
      "type": "string"
    },
    "candidate_media_rendered": {
      "default": false,
      "title": "Candidate Media Rendered",
      "type": "boolean"
    },
    "canonical_timeline_mutated": {
      "default": false,
      "title": "Canonical Timeline Mutated",
      "type": "boolean"
    },
    "concept_duration_overridden": {
      "default": false,
      "title": "Concept Duration Overridden",
      "type": "boolean"
    },
    "concept_duration_seconds": {
      "exclusiveMinimum": 0,
      "title": "Concept Duration Seconds",
      "type": "number"
    },
    "deterministic_action_count": {
      "minimum": 0,
      "title": "Deterministic Action Count",
      "type": "integer"
    },
    "edit_points_applied": {
      "default": false,
      "title": "Edit Points Applied",
      "type": "boolean"
    },
    "manual_boundary_action_count": {
      "minimum": 0,
      "title": "Manual Boundary Action Count",
      "type": "integer"
    },
    "model_call_performed_by_cli": {
      "default": false,
      "title": "Model Call Performed By Cli",
      "type": "boolean"
    },
    "music_selected": {
      "default": false,
      "title": "Music Selected",
      "type": "boolean"
    },
    "network_performed": {
      "default": false,
      "title": "Network Performed",
      "type": "boolean"
    },
    "ordered_segment_ids": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "title": "Ordered Segment Ids",
      "type": "array"
    },
    "owned_issue_ids": {
      "items": {
        "type": "string"
      },
      "title": "Owned Issue Ids",
      "type": "array"
    },
    "project_id": {
      "minLength": 1,
      "title": "Project Id",
      "type": "string"
    },
    "reframes_applied": {
      "default": false,
      "title": "Reframes Applied",
      "type": "boolean"
    },
    "schema_version": {
      "default": "0.3",
      "title": "Schema Version",
      "type": "string"
    },
    "selected_concept_id": {
      "pattern": "^concept_[a-z0-9_]+$",
      "title": "Selected Concept Id",
      "type": "string"
    },
    "selected_concept_name": {
      "minLength": 1,
      "title": "Selected Concept Name",
      "type": "string"
    },
    "status": {
      "pattern": "^(ready|warning|blocked)$",
      "title": "Status",
      "type": "string"
    },
    "target_duration_seconds": {
      "exclusiveMinimum": 0,
      "title": "Target Duration Seconds",
      "type": "number"
    },
    "target_duration_source": {
      "pattern": "^(project_config|aesthetic_concept)$",
      "title": "Target Duration Source",
      "type": "string"
    },
    "unowned_high_priority_issue_ids": {
      "items": {
        "type": "string"
      },
      "title": "Unowned High Priority Issue Ids",
      "type": "array"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "candidate_id",
    "project_id",
    "aesthetic_baseline_id",
    "aesthetic_baseline_ref",
    "aesthetic_baseline_fingerprint",
    "baseline_timeline_id",
    "baseline_timeline_ref",
    "baseline_timeline_fingerprint",
    "selected_concept_id",
    "selected_concept_name",
    "target_duration_seconds",
    "target_duration_source",
    "concept_duration_seconds",
    "status",
    "action_count",
    "deterministic_action_count",
    "manual_boundary_action_count",
    "blocked_action_count",
    "actions",
    "ordered_segment_ids",
    "acceptance_requirements"
  ],
  "title": "SecondCutCandidate",
  "type": "object"
}
