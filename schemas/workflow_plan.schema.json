{
  "$defs": {
    "CreatorWorkflowDeliverable": {
      "additionalProperties": false,
      "properties": {
        "deliverable_id": {
          "minLength": 1,
          "title": "Deliverable Id",
          "type": "string"
        },
        "label": {
          "minLength": 1,
          "title": "Label",
          "type": "string"
        },
        "refs": {
          "items": {
            "type": "string"
          },
          "title": "Refs",
          "type": "array"
        },
        "stage_id": {
          "minLength": 1,
          "title": "Stage Id",
          "type": "string"
        },
        "status": {
          "pattern": "^(present|missing|blocked)$",
          "title": "Status",
          "type": "string"
        },
        "summary": {
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        }
      },
      "required": [
        "deliverable_id",
        "stage_id",
        "label",
        "status",
        "summary"
      ],
      "title": "CreatorWorkflowDeliverable",
      "type": "object"
    },
    "CreatorWorkflowStage": {
      "additionalProperties": false,
      "properties": {
        "blocking_step_ids": {
          "items": {
            "type": "string"
          },
          "title": "Blocking Step Ids",
          "type": "array"
        },
        "deliverable_refs": {
          "items": {
            "type": "string"
          },
          "title": "Deliverable Refs",
          "type": "array"
        },
        "next_command": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Next Command"
        },
        "order": {
          "minimum": 1,
          "title": "Order",
          "type": "integer"
        },
        "stage_id": {
          "minLength": 1,
          "title": "Stage Id",
          "type": "string"
        },
        "status": {
          "pattern": "^(done|current|pending|blocked)$",
          "title": "Status",
          "type": "string"
        },
        "step_ids": {
          "items": {
            "type": "string"
          },
          "title": "Step Ids",
          "type": "array"
        },
        "summary": {
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        },
        "title": {
          "minLength": 1,
          "title": "Title",
          "type": "string"
        }
      },
      "required": [
        "stage_id",
        "order",
        "title",
        "status",
        "summary"
      ],
      "title": "CreatorWorkflowStage",
      "type": "object"
    },
    "WorkflowStep": {
      "additionalProperties": false,
      "properties": {
        "command": {
          "minLength": 1,
          "title": "Command",
          "type": "string"
        },
        "executes_automatically": {
          "default": false,
          "title": "Executes Automatically",
          "type": "boolean"
        },
        "expected_artifacts": {
          "items": {
            "type": "string"
          },
          "title": "Expected Artifacts",
          "type": "array"
        },
        "order": {
          "minimum": 1,
          "title": "Order",
          "type": "integer"
        },
        "phase": {
          "minLength": 1,
          "title": "Phase",
          "type": "string"
        },
        "rationale": {
          "minLength": 1,
          "title": "Rationale",
          "type": "string"
        },
        "source": {
          "pattern": "^(workflow|acceptance|rhythm_repair|state)$",
          "title": "Source",
          "type": "string"
        },
        "status": {
          "pattern": "^(done|next|pending|blocked|optional)$",
          "title": "Status",
          "type": "string"
        },
        "step_id": {
          "minLength": 1,
          "title": "Step Id",
          "type": "string"
        }
      },
      "required": [
        "step_id",
        "order",
        "phase",
        "status",
        "command",
        "rationale",
        "source"
      ],
      "title": "WorkflowStep",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "automatic_music_selection": {
      "default": false,
      "title": "Automatic Music Selection",
      "type": "boolean"
    },
    "bgm_input_guidance": {
      "items": {
        "type": "string"
      },
      "title": "Bgm Input Guidance",
      "type": "array"
    },
    "blocked_step_count": {
      "minimum": 0,
      "title": "Blocked Step Count",
      "type": "integer"
    },
    "commands_executed": {
      "default": false,
      "title": "Commands Executed",
      "type": "boolean"
    },
    "completed_step_count": {
      "minimum": 0,
      "title": "Completed Step Count",
      "type": "integer"
    },
    "creator_stage_count": {
      "minimum": 0,
      "title": "Creator Stage Count",
      "type": "integer"
    },
    "creator_stages": {
      "items": {
        "$ref": "#/$defs/CreatorWorkflowStage"
      },
      "title": "Creator Stages",
      "type": "array"
    },
    "current_stage_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Current Stage Id"
    },
    "current_stage_title": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Current Stage Title"
    },
    "deliverables": {
      "items": {
        "$ref": "#/$defs/CreatorWorkflowDeliverable"
      },
      "title": "Deliverables",
      "type": "array"
    },
    "edit_points_moved": {
      "default": false,
      "title": "Edit Points Moved",
      "type": "boolean"
    },
    "media_rendered": {
      "default": false,
      "title": "Media Rendered",
      "type": "boolean"
    },
    "model_call_performed_by_cli": {
      "default": false,
      "title": "Model Call Performed By Cli",
      "type": "boolean"
    },
    "network_performed": {
      "default": false,
      "title": "Network Performed",
      "type": "boolean"
    },
    "next_command": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Next Command"
    },
    "project_id": {
      "minLength": 1,
      "title": "Project Id",
      "type": "string"
    },
    "remaining_step_count": {
      "minimum": 0,
      "title": "Remaining Step Count",
      "type": "integer"
    },
    "schema_version": {
      "default": "0.3",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "pattern": "^(ready|in_progress|blocked)$",
      "title": "Status",
      "type": "string"
    },
    "steps": {
      "items": {
        "$ref": "#/$defs/WorkflowStep"
      },
      "title": "Steps",
      "type": "array"
    },
    "target": {
      "pattern": "^(core|preview|delivery)$",
      "title": "Target",
      "type": "string"
    },
    "workflow_plan_id": {
      "minLength": 1,
      "title": "Workflow Plan Id",
      "type": "string"
    }
  },
  "required": [
    "workflow_plan_id",
    "project_id",
    "target",
    "status",
    "completed_step_count",
    "remaining_step_count",
    "blocked_step_count",
    "creator_stage_count"
  ],
  "title": "WorkflowPlan",
  "type": "object"
}
