{
  "$defs": {
    "BgmInputMode": {
      "enum": [
        "direct_audio",
        "video_audio_extract",
        "source_embedded_audio"
      ],
      "title": "BgmInputMode",
      "type": "string"
    },
    "BgmRhythmCandidateInsight": {
      "additionalProperties": false,
      "properties": {
        "beat_analysis_status": {
          "pattern": "^(unavailable|completed)$",
          "title": "Beat Analysis Status",
          "type": "string"
        },
        "beat_count": {
          "minimum": 0,
          "title": "Beat Count",
          "type": "integer"
        },
        "beat_grid_fingerprint": {
          "anyOf": [
            {
              "pattern": "^sha256:[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Beat Grid Fingerprint"
        },
        "beat_grid_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Beat Grid Ref"
        },
        "beat_quality_score": {
          "maximum": 1,
          "minimum": 0,
          "title": "Beat Quality Score",
          "type": "number"
        },
        "beat_quality_status": {
          "pattern": "^(unavailable|weak|usable|strong)$",
          "title": "Beat Quality Status",
          "type": "string"
        },
        "bpm": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Bpm"
        },
        "estimated_bar_seconds": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Estimated Bar Seconds"
        },
        "estimated_phrase_seconds": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Estimated Phrase Seconds"
        },
        "input_mode": {
          "$ref": "#/$defs/BgmInputMode"
        },
        "mixed_audio": {
          "title": "Mixed Audio",
          "type": "boolean"
        },
        "music_candidate_id": {
          "minLength": 1,
          "title": "Music Candidate Id",
          "type": "string"
        },
        "next_actions": {
          "items": {
            "type": "string"
          },
          "title": "Next Actions",
          "type": "array"
        },
        "phrase_hint_status": {
          "pattern": "^(unavailable|estimated)$",
          "title": "Phrase Hint Status",
          "type": "string"
        },
        "source_ref": {
          "minLength": 1,
          "title": "Source Ref",
          "type": "string"
        },
        "source_risk_status": {
          "pattern": "^(low|medium|high)$",
          "title": "Source Risk Status",
          "type": "string"
        },
        "tempo_confidence": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tempo Confidence"
        },
        "warnings": {
          "items": {
            "type": "string"
          },
          "title": "Warnings",
          "type": "array"
        }
      },
      "required": [
        "music_candidate_id",
        "input_mode",
        "source_ref",
        "mixed_audio",
        "beat_analysis_status",
        "beat_count",
        "beat_quality_status",
        "beat_quality_score",
        "phrase_hint_status",
        "source_risk_status"
      ],
      "title": "BgmRhythmCandidateInsight",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "automatic_music_selection": {
      "default": false,
      "title": "Automatic Music Selection",
      "type": "boolean"
    },
    "beat_completed_count": {
      "minimum": 0,
      "title": "Beat Completed Count",
      "type": "integer"
    },
    "bgm_analysis_fingerprint": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Bgm Analysis Fingerprint",
      "type": "string"
    },
    "bgm_analysis_ref": {
      "default": ".artist-portrait/data/bgm_analysis.json",
      "title": "Bgm Analysis Ref",
      "type": "string"
    },
    "bgm_rhythm_intelligence_id": {
      "minLength": 1,
      "title": "Bgm Rhythm Intelligence Id",
      "type": "string"
    },
    "candidate_count": {
      "minimum": 0,
      "title": "Candidate Count",
      "type": "integer"
    },
    "candidate_ledger_fingerprint": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Candidate Ledger Fingerprint",
      "type": "string"
    },
    "candidate_ledger_ref": {
      "default": ".artist-portrait/data/bgm_candidates.json",
      "title": "Candidate Ledger Ref",
      "type": "string"
    },
    "candidates": {
      "items": {
        "$ref": "#/$defs/BgmRhythmCandidateInsight"
      },
      "title": "Candidates",
      "type": "array"
    },
    "edit_points_moved": {
      "default": false,
      "title": "Edit Points Moved",
      "type": "boolean"
    },
    "fabricated_bpm_or_beats": {
      "default": false,
      "title": "Fabricated Bpm Or Beats",
      "type": "boolean"
    },
    "media_rendered": {
      "default": false,
      "title": "Media Rendered",
      "type": "boolean"
    },
    "mixed_audio_candidate_count": {
      "minimum": 0,
      "title": "Mixed Audio Candidate Count",
      "type": "integer"
    },
    "model_call_performed_by_cli": {
      "default": false,
      "title": "Model Call Performed By Cli",
      "type": "boolean"
    },
    "network_performed": {
      "default": false,
      "title": "Network Performed",
      "type": "boolean"
    },
    "project_id": {
      "minLength": 1,
      "title": "Project Id",
      "type": "string"
    },
    "schema_version": {
      "default": "0.3",
      "title": "Schema Version",
      "type": "string"
    },
    "source_modes_present": {
      "items": {
        "$ref": "#/$defs/BgmInputMode"
      },
      "title": "Source Modes Present",
      "type": "array"
    },
    "status": {
      "pattern": "^(passed|warning|blocked)$",
      "title": "Status",
      "type": "string"
    },
    "summary": {
      "minLength": 1,
      "title": "Summary",
      "type": "string"
    },
    "usable_beat_candidate_count": {
      "minimum": 0,
      "title": "Usable Beat Candidate Count",
      "type": "integer"
    }
  },
  "required": [
    "bgm_rhythm_intelligence_id",
    "project_id",
    "candidate_ledger_fingerprint",
    "bgm_analysis_fingerprint",
    "candidate_count",
    "beat_completed_count",
    "usable_beat_candidate_count",
    "mixed_audio_candidate_count",
    "status",
    "summary"
  ],
  "title": "BgmRhythmIntelligenceReport",
  "type": "object"
}
