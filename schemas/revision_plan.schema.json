{
  "$defs": {
    "RevisionAction": {
      "additionalProperties": false,
      "properties": {
        "acceptance_observations": {
          "items": {
            "type": "string"
          },
          "title": "Acceptance Observations",
          "type": "array"
        },
        "action_id": {
          "minLength": 1,
          "title": "Action Id",
          "type": "string"
        },
        "action_type": {
          "pattern": "^(trim|extend|keep|remove|frontload_hook|strengthen_emotion|replace_ending|reduce_subtitles|rebalance_bgm|refine_style|accelerate_pacing|protect_voice|adjust_transition|manual_review)$",
          "title": "Action Type",
          "type": "string"
        },
        "affected_domains": {
          "items": {
            "type": "string"
          },
          "title": "Affected Domains",
          "type": "array"
        },
        "application_status": {
          "default": "planned",
          "pattern": "^(planned|applied|manual_only|blocked|skipped)$",
          "title": "Application Status",
          "type": "string"
        },
        "edits_applied": {
          "default": false,
          "title": "Edits Applied",
          "type": "boolean"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "expected_effect": {
          "minLength": 1,
          "title": "Expected Effect",
          "type": "string"
        },
        "manual_only": {
          "default": true,
          "title": "Manual Only",
          "type": "boolean"
        },
        "order": {
          "minimum": 1,
          "title": "Order",
          "type": "integer"
        },
        "rationale": {
          "minLength": 1,
          "title": "Rationale",
          "type": "string"
        },
        "recommendation": {
          "minLength": 1,
          "title": "Recommendation",
          "type": "string"
        },
        "required_for_intent": {
          "default": true,
          "title": "Required For Intent",
          "type": "boolean"
        },
        "segment_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Segment Id"
        },
        "timeline_end": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Timeline End"
        },
        "timeline_start": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Timeline Start"
        }
      },
      "required": [
        "action_id",
        "order",
        "action_type",
        "recommendation",
        "rationale",
        "expected_effect"
      ],
      "title": "RevisionAction",
      "type": "object"
    },
    "RevisionComparison": {
      "additionalProperties": false,
      "properties": {
        "baseline_version_id": {
          "minLength": 1,
          "title": "Baseline Version Id",
          "type": "string"
        },
        "improvement_axes": {
          "items": {
            "type": "string"
          },
          "title": "Improvement Axes",
          "type": "array"
        },
        "recommended_version_id": {
          "minLength": 1,
          "title": "Recommended Version Id",
          "type": "string"
        },
        "risk_axes": {
          "items": {
            "type": "string"
          },
          "title": "Risk Axes",
          "type": "array"
        },
        "summary": {
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        }
      },
      "required": [
        "baseline_version_id",
        "recommended_version_id",
        "summary"
      ],
      "title": "RevisionComparison",
      "type": "object"
    },
    "RevisionIntent": {
      "additionalProperties": false,
      "properties": {
        "classification_reasons": {
          "items": {
            "type": "string"
          },
          "title": "Classification Reasons",
          "type": "array"
        },
        "intent_id": {
          "minLength": 1,
          "title": "Intent Id",
          "type": "string"
        },
        "keep_segment_ids": {
          "items": {
            "type": "string"
          },
          "title": "Keep Segment Ids",
          "type": "array"
        },
        "remove_segment_ids": {
          "items": {
            "type": "string"
          },
          "title": "Remove Segment Ids",
          "type": "array"
        },
        "request_text": {
          "minLength": 1,
          "title": "Request Text",
          "type": "string"
        },
        "request_type": {
          "pattern": "^(shorter|longer|stronger_hook|more_emotional|keep_segment|remove_segment|change_ending|reduce_subtitles|reduce_bgm|custom)$",
          "title": "Request Type",
          "type": "string"
        },
        "source": {
          "default": "cli",
          "pattern": "^(cli|host_agent|imported)$",
          "title": "Source",
          "type": "string"
        },
        "target_duration_seconds": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Target Duration Seconds"
        }
      },
      "required": [
        "intent_id",
        "request_text",
        "request_type"
      ],
      "title": "RevisionIntent",
      "type": "object"
    },
    "RevisionSemanticClause": {
      "additionalProperties": false,
      "properties": {
        "acceptance_observations": {
          "items": {
            "type": "string"
          },
          "title": "Acceptance Observations",
          "type": "array"
        },
        "application_status": {
          "default": "planned",
          "pattern": "^(planned|applied|manual_only|blocked|unavailable)$",
          "title": "Application Status",
          "type": "string"
        },
        "clause_id": {
          "minLength": 1,
          "title": "Clause Id",
          "type": "string"
        },
        "confidence": {
          "maximum": 1,
          "minimum": 0,
          "title": "Confidence",
          "type": "number"
        },
        "coupled_domains": {
          "items": {
            "type": "string"
          },
          "title": "Coupled Domains",
          "type": "array"
        },
        "domain": {
          "pattern": "^(duration|structure|rhythm|emotion|style|text|source_audio|bgm|transition|ending|constraint|custom)$",
          "title": "Domain",
          "type": "string"
        },
        "evidence_requirements": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Requirements",
          "type": "array"
        },
        "intensity": {
          "pattern": "^(subtle|moderate|strong|unspecified)$",
          "title": "Intensity",
          "type": "string"
        },
        "matched_text": {
          "items": {
            "type": "string"
          },
          "title": "Matched Text",
          "type": "array"
        },
        "operation": {
          "minLength": 1,
          "title": "Operation",
          "type": "string"
        },
        "priority": {
          "minimum": 1,
          "title": "Priority",
          "type": "integer"
        },
        "scope": {
          "pattern": "^(opening|middle|ending|segment|whole_cut)$",
          "title": "Scope",
          "type": "string"
        }
      },
      "required": [
        "clause_id",
        "domain",
        "operation",
        "intensity",
        "scope",
        "priority",
        "confidence"
      ],
      "title": "RevisionSemanticClause",
      "type": "object"
    },
    "RevisionSemanticConflict": {
      "additionalProperties": false,
      "properties": {
        "clause_ids": {
          "items": {
            "type": "string"
          },
          "minItems": 2,
          "title": "Clause Ids",
          "type": "array"
        },
        "conflict_id": {
          "minLength": 1,
          "title": "Conflict Id",
          "type": "string"
        },
        "description": {
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "resolution": {
          "minLength": 1,
          "title": "Resolution",
          "type": "string"
        },
        "status": {
          "pattern": "^(warning|blocked)$",
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "conflict_id",
        "clause_ids",
        "description",
        "resolution",
        "status"
      ],
      "title": "RevisionSemanticConflict",
      "type": "object"
    },
    "RevisionVersionCandidate": {
      "additionalProperties": false,
      "properties": {
        "action_ids": {
          "items": {
            "type": "string"
          },
          "title": "Action Ids",
          "type": "array"
        },
        "current_version": {
          "default": false,
          "title": "Current Version",
          "type": "boolean"
        },
        "duration_delta_seconds": {
          "title": "Duration Delta Seconds",
          "type": "number"
        },
        "edits_applied": {
          "default": false,
          "title": "Edits Applied",
          "type": "boolean"
        },
        "estimated_duration_seconds": {
          "exclusiveMinimum": 0,
          "title": "Estimated Duration Seconds",
          "type": "number"
        },
        "expected_improvements": {
          "items": {
            "type": "string"
          },
          "title": "Expected Improvements",
          "type": "array"
        },
        "label": {
          "minLength": 1,
          "title": "Label",
          "type": "string"
        },
        "risk_level": {
          "pattern": "^(low|medium|high)$",
          "title": "Risk Level",
          "type": "string"
        },
        "satisfies_intent": {
          "title": "Satisfies Intent",
          "type": "boolean"
        },
        "strategy": {
          "minLength": 1,
          "title": "Strategy",
          "type": "string"
        },
        "tradeoffs": {
          "items": {
            "type": "string"
          },
          "title": "Tradeoffs",
          "type": "array"
        },
        "version_id": {
          "minLength": 1,
          "title": "Version Id",
          "type": "string"
        }
      },
      "required": [
        "version_id",
        "label",
        "strategy",
        "estimated_duration_seconds",
        "duration_delta_seconds",
        "risk_level",
        "satisfies_intent"
      ],
      "title": "RevisionVersionCandidate",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "action_count": {
      "minimum": 0,
      "title": "Action Count",
      "type": "integer"
    },
    "actions": {
      "items": {
        "$ref": "#/$defs/RevisionAction"
      },
      "title": "Actions",
      "type": "array"
    },
    "automatic_bgm_fit": {
      "default": false,
      "title": "Automatic Bgm Fit",
      "type": "boolean"
    },
    "automatic_music_selection": {
      "default": false,
      "title": "Automatic Music Selection",
      "type": "boolean"
    },
    "candidate_count": {
      "minimum": 0,
      "title": "Candidate Count",
      "type": "integer"
    },
    "commands_executed": {
      "default": false,
      "title": "Commands Executed",
      "type": "boolean"
    },
    "comparison": {
      "$ref": "#/$defs/RevisionComparison"
    },
    "covered_domains": {
      "items": {
        "type": "string"
      },
      "title": "Covered Domains",
      "type": "array"
    },
    "current_duration_seconds": {
      "exclusiveMinimum": 0,
      "title": "Current Duration Seconds",
      "type": "number"
    },
    "cut_review_fingerprint": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Cut Review Fingerprint",
      "type": "string"
    },
    "cut_review_id": {
      "minLength": 1,
      "title": "Cut Review Id",
      "type": "string"
    },
    "cut_review_ref": {
      "minLength": 1,
      "title": "Cut Review Ref",
      "type": "string"
    },
    "edit_points_moved": {
      "default": false,
      "title": "Edit Points Moved",
      "type": "boolean"
    },
    "final_export_validation_fingerprint": {
      "anyOf": [
        {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Final Export Validation Fingerprint"
    },
    "final_export_validation_ref": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Final Export Validation Ref"
    },
    "first_action_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "First Action Id"
    },
    "image_generation_or_editing_used": {
      "default": false,
      "title": "Image Generation Or Editing Used",
      "type": "boolean"
    },
    "intent": {
      "$ref": "#/$defs/RevisionIntent"
    },
    "media_rendered": {
      "default": false,
      "title": "Media Rendered",
      "type": "boolean"
    },
    "model_call_performed_by_cli": {
      "default": false,
      "title": "Model Call Performed By Cli",
      "type": "boolean"
    },
    "network_performed": {
      "default": false,
      "title": "Network Performed",
      "type": "boolean"
    },
    "preview_validation_fingerprint": {
      "anyOf": [
        {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Preview Validation Fingerprint"
    },
    "preview_validation_ref": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Preview Validation Ref"
    },
    "project_id": {
      "minLength": 1,
      "title": "Project Id",
      "type": "string"
    },
    "recommended_version_id": {
      "minLength": 1,
      "title": "Recommended Version Id",
      "type": "string"
    },
    "revision_plan_id": {
      "minLength": 1,
      "title": "Revision Plan Id",
      "type": "string"
    },
    "rhythm_plan_fingerprint": {
      "anyOf": [
        {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Rhythm Plan Fingerprint"
    },
    "rhythm_plan_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Rhythm Plan Id"
    },
    "schema_version": {
      "default": "0.3",
      "title": "Schema Version",
      "type": "string"
    },
    "semantic_clauses": {
      "items": {
        "$ref": "#/$defs/RevisionSemanticClause"
      },
      "title": "Semantic Clauses",
      "type": "array"
    },
    "semantic_conflicts": {
      "items": {
        "$ref": "#/$defs/RevisionSemanticConflict"
      },
      "title": "Semantic Conflicts",
      "type": "array"
    },
    "sound_decision_fingerprint": {
      "anyOf": [
        {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Sound Decision Fingerprint"
    },
    "sound_decision_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Sound Decision Id"
    },
    "status": {
      "pattern": "^(ready|warning|blocked)$",
      "title": "Status",
      "type": "string"
    },
    "target_duration_seconds": {
      "anyOf": [
        {
          "exclusiveMinimum": 0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Target Duration Seconds"
    },
    "timeline_fingerprint": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Timeline Fingerprint",
      "type": "string"
    },
    "timeline_id": {
      "minLength": 1,
      "title": "Timeline Id",
      "type": "string"
    },
    "timeline_mutated": {
      "default": false,
      "title": "Timeline Mutated",
      "type": "boolean"
    },
    "timeline_ref": {
      "minLength": 1,
      "title": "Timeline Ref",
      "type": "string"
    },
    "version_candidates": {
      "items": {
        "$ref": "#/$defs/RevisionVersionCandidate"
      },
      "minItems": 1,
      "title": "Version Candidates",
      "type": "array"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "revision_plan_id",
    "project_id",
    "status",
    "timeline_id",
    "timeline_ref",
    "timeline_fingerprint",
    "cut_review_id",
    "cut_review_ref",
    "cut_review_fingerprint",
    "intent",
    "current_duration_seconds",
    "action_count",
    "candidate_count",
    "recommended_version_id",
    "version_candidates",
    "comparison"
  ],
  "title": "RevisionPlan",
  "type": "object"
}
