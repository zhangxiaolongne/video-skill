{
  "$defs": {
    "AudioTransition": {
      "enum": [
        "none",
        "cut",
        "crossfade",
        "fade_in",
        "fade_out",
        "j_cut",
        "l_cut"
      ],
      "title": "AudioTransition",
      "type": "string"
    },
    "EvidenceRef": {
      "additionalProperties": false,
      "properties": {
        "ref": {
          "minLength": 1,
          "title": "Ref",
          "type": "string"
        },
        "type": {
          "minLength": 1,
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "type",
        "ref"
      ],
      "title": "EvidenceRef",
      "type": "object"
    },
    "MediaRole": {
      "enum": [
        "video",
        "audio",
        "both"
      ],
      "title": "MediaRole",
      "type": "string"
    },
    "MusicSlotStatus": {
      "enum": [
        "unresolved",
        "disabled_by_policy",
        "fitted"
      ],
      "title": "MusicSlotStatus",
      "type": "string"
    },
    "ProposalId": {
      "enum": [
        "proposal_safe",
        "proposal_advanced",
        "proposal_risky"
      ],
      "title": "ProposalId",
      "type": "string"
    },
    "TimelineContinuityCheck": {
      "additionalProperties": false,
      "properties": {
        "detail": {
          "minLength": 1,
          "title": "Detail",
          "type": "string"
        },
        "from_segment_id": {
          "title": "From Segment Id",
          "type": "string"
        },
        "risk_level": {
          "pattern": "^(low|medium|high)$",
          "title": "Risk Level",
          "type": "string"
        },
        "status": {
          "pattern": "^(same_source_continuous|same_source_jump|cross_source_cut|audio_only_transition)$",
          "title": "Status",
          "type": "string"
        },
        "to_segment_id": {
          "title": "To Segment Id",
          "type": "string"
        }
      },
      "required": [
        "from_segment_id",
        "to_segment_id",
        "status",
        "detail",
        "risk_level"
      ],
      "title": "TimelineContinuityCheck",
      "type": "object"
    },
    "TimelineDroppedClip": {
      "additionalProperties": false,
      "properties": {
        "clip_id": {
          "minLength": 1,
          "title": "Clip Id",
          "type": "string"
        },
        "overall_score": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Overall Score"
        },
        "reason": {
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        },
        "selection_tier": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Selection Tier"
        },
        "source_id": {
          "minLength": 1,
          "title": "Source Id",
          "type": "string"
        }
      },
      "required": [
        "clip_id",
        "source_id",
        "reason"
      ],
      "title": "TimelineDroppedClip",
      "type": "object"
    },
    "TimelineDurationVariant": {
      "additionalProperties": false,
      "properties": {
        "estimated_duration": {
          "minimum": 0,
          "title": "Estimated Duration",
          "type": "number"
        },
        "label": {
          "minLength": 1,
          "title": "Label",
          "type": "string"
        },
        "option_id": {
          "minLength": 1,
          "title": "Option Id",
          "type": "string"
        },
        "rationale": {
          "items": {
            "type": "string"
          },
          "title": "Rationale",
          "type": "array"
        },
        "risks": {
          "items": {
            "type": "string"
          },
          "title": "Risks",
          "type": "array"
        },
        "role_allocation": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Role Allocation",
          "type": "object"
        },
        "target_duration": {
          "exclusiveMinimum": 0,
          "title": "Target Duration",
          "type": "number"
        }
      },
      "required": [
        "option_id",
        "label",
        "target_duration",
        "estimated_duration"
      ],
      "title": "TimelineDurationVariant",
      "type": "object"
    },
    "TimelineMusicPlan": {
      "additionalProperties": false,
      "properties": {
        "beat_analysis_performed": {
          "default": false,
          "title": "Beat Analysis Performed",
          "type": "boolean"
        },
        "candidate_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Candidate Id"
        },
        "fit_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fit Ref"
        },
        "fitting_performed": {
          "default": false,
          "title": "Fitting Performed",
          "type": "boolean"
        },
        "future_input_modes": {
          "items": {
            "type": "string"
          },
          "minItems": 5,
          "title": "Future Input Modes",
          "type": "array"
        },
        "input_mode": {
          "pattern": "^(none_yet|disabled_by_policy|direct_audio|video_audio_extract|source_embedded_audio)$",
          "title": "Input Mode",
          "type": "string"
        },
        "proposal_sound_structure": {
          "items": {
            "type": "string"
          },
          "title": "Proposal Sound Structure",
          "type": "array"
        },
        "selection_performed": {
          "default": false,
          "title": "Selection Performed",
          "type": "boolean"
        },
        "status": {
          "$ref": "#/$defs/MusicSlotStatus"
        }
      },
      "required": [
        "status",
        "input_mode",
        "future_input_modes"
      ],
      "title": "TimelineMusicPlan",
      "type": "object"
    },
    "TimelineSegment": {
      "additionalProperties": false,
      "properties": {
        "audio_transition": {
          "$ref": "#/$defs/AudioTransition"
        },
        "clip_id": {
          "minLength": 1,
          "title": "Clip Id",
          "type": "string"
        },
        "clip_overall_score": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Clip Overall Score"
        },
        "clip_score_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Clip Score Id"
        },
        "confidence": {
          "maximum": 1,
          "minimum": 0,
          "title": "Confidence",
          "type": "number"
        },
        "continuity_note": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Continuity Note"
        },
        "creative_intent": {
          "minLength": 1,
          "title": "Creative Intent",
          "type": "string"
        },
        "evidence": {
          "items": {
            "$ref": "#/$defs/EvidenceRef"
          },
          "minItems": 1,
          "title": "Evidence",
          "type": "array"
        },
        "keep_reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Keep Reason"
        },
        "media_role": {
          "$ref": "#/$defs/MediaRole"
        },
        "reason": {
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        },
        "segment_id": {
          "minLength": 1,
          "title": "Segment Id",
          "type": "string"
        },
        "selection_tier": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Selection Tier"
        },
        "source_id": {
          "minLength": 1,
          "title": "Source Id",
          "type": "string"
        },
        "source_in": {
          "minimum": 0,
          "title": "Source In",
          "type": "number"
        },
        "source_out": {
          "exclusiveMinimum": 0,
          "title": "Source Out",
          "type": "number"
        },
        "structural_role": {
          "$ref": "#/$defs/TimelineStructuralRole",
          "default": "build"
        },
        "timeline_end": {
          "exclusiveMinimum": 0,
          "title": "Timeline End",
          "type": "number"
        },
        "timeline_start": {
          "minimum": 0,
          "title": "Timeline Start",
          "type": "number"
        },
        "track_id": {
          "minLength": 1,
          "title": "Track Id",
          "type": "string"
        },
        "video_transition": {
          "$ref": "#/$defs/VideoTransition"
        }
      },
      "required": [
        "segment_id",
        "timeline_start",
        "timeline_end",
        "clip_id",
        "source_id",
        "source_in",
        "source_out",
        "track_id",
        "media_role",
        "video_transition",
        "audio_transition",
        "reason",
        "evidence",
        "creative_intent",
        "confidence"
      ],
      "title": "TimelineSegment",
      "type": "object"
    },
    "TimelineStructuralRole": {
      "enum": [
        "hook",
        "build",
        "payoff",
        "bridge",
        "context"
      ],
      "title": "TimelineStructuralRole",
      "type": "string"
    },
    "VideoTransition": {
      "enum": [
        "none",
        "hard_cut",
        "crossfade",
        "fade_in",
        "fade_out",
        "match_cut"
      ],
      "title": "VideoTransition",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "actual_duration": {
      "exclusiveMinimum": 0,
      "title": "Actual Duration",
      "type": "number"
    },
    "automatic_bgm_fit": {
      "default": false,
      "title": "Automatic Bgm Fit",
      "type": "boolean"
    },
    "automatic_music_selection": {
      "default": false,
      "title": "Automatic Music Selection",
      "type": "boolean"
    },
    "clip_scores_fingerprint": {
      "default": "",
      "title": "Clip Scores Fingerprint",
      "type": "string"
    },
    "clip_scores_ref": {
      "default": "",
      "title": "Clip Scores Ref",
      "type": "string"
    },
    "commands_executed": {
      "default": false,
      "title": "Commands Executed",
      "type": "boolean"
    },
    "continuity_checks": {
      "items": {
        "$ref": "#/$defs/TimelineContinuityCheck"
      },
      "title": "Continuity Checks",
      "type": "array"
    },
    "dropped_clips": {
      "items": {
        "$ref": "#/$defs/TimelineDroppedClip"
      },
      "title": "Dropped Clips",
      "type": "array"
    },
    "duration_variants": {
      "items": {
        "$ref": "#/$defs/TimelineDurationVariant"
      },
      "title": "Duration Variants",
      "type": "array"
    },
    "edit_brief_fingerprint": {
      "default": "",
      "title": "Edit Brief Fingerprint",
      "type": "string"
    },
    "edit_brief_ref": {
      "default": "",
      "title": "Edit Brief Ref",
      "type": "string"
    },
    "edit_points_moved": {
      "default": false,
      "title": "Edit Points Moved",
      "type": "boolean"
    },
    "evidence": {
      "items": {
        "$ref": "#/$defs/EvidenceRef"
      },
      "minItems": 1,
      "title": "Evidence",
      "type": "array"
    },
    "image_generation_or_editing_used": {
      "default": false,
      "title": "Image Generation Or Editing Used",
      "type": "boolean"
    },
    "input_fingerprint": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Input Fingerprint",
      "type": "string"
    },
    "media_rendered": {
      "default": false,
      "title": "Media Rendered",
      "type": "boolean"
    },
    "model_call_performed_by_cli": {
      "default": false,
      "title": "Model Call Performed By Cli",
      "type": "boolean"
    },
    "music_plan": {
      "$ref": "#/$defs/TimelineMusicPlan"
    },
    "network_performed": {
      "default": false,
      "title": "Network Performed",
      "type": "boolean"
    },
    "no_fabricated_content_claims": {
      "default": true,
      "title": "No Fabricated Content Claims",
      "type": "boolean"
    },
    "project_id": {
      "minLength": 1,
      "title": "Project Id",
      "type": "string"
    },
    "proposal_id": {
      "$ref": "#/$defs/ProposalId"
    },
    "proposal_map_fingerprint": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Proposal Map Fingerprint",
      "type": "string"
    },
    "proposal_set_id": {
      "minLength": 1,
      "title": "Proposal Set Id",
      "type": "string"
    },
    "risks": {
      "items": {
        "type": "string"
      },
      "title": "Risks",
      "type": "array"
    },
    "schema_version": {
      "default": "0.3",
      "title": "Schema Version",
      "type": "string"
    },
    "segments": {
      "items": {
        "$ref": "#/$defs/TimelineSegment"
      },
      "minItems": 1,
      "title": "Segments",
      "type": "array"
    },
    "selected_duration_option_id": {
      "default": "",
      "title": "Selected Duration Option Id",
      "type": "string"
    },
    "structure_strategy": {
      "items": {
        "type": "string"
      },
      "title": "Structure Strategy",
      "type": "array"
    },
    "target_duration": {
      "exclusiveMinimum": 0,
      "title": "Target Duration",
      "type": "number"
    },
    "timeline_id": {
      "minLength": 1,
      "title": "Timeline Id",
      "type": "string"
    },
    "timeline_mutated": {
      "default": false,
      "title": "Timeline Mutated",
      "type": "boolean"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "timeline_id",
    "project_id",
    "proposal_set_id",
    "proposal_id",
    "proposal_map_fingerprint",
    "input_fingerprint",
    "target_duration",
    "actual_duration",
    "segments",
    "music_plan",
    "evidence"
  ],
  "title": "TimelineDraft",
  "type": "object"
}
