{
  "$defs": {
    "ContentPolicy": {
      "additionalProperties": false,
      "properties": {
        "allow_interview_audio": {
          "title": "Allow Interview Audio",
          "type": "boolean"
        },
        "allow_music": {
          "title": "Allow Music",
          "type": "boolean"
        },
        "allow_real_person_role_mix": {
          "title": "Allow Real Person Role Mix",
          "type": "boolean"
        },
        "allow_restricted_rights": {
          "title": "Allow Restricted Rights",
          "type": "boolean"
        },
        "allow_role_dialogue": {
          "title": "Allow Role Dialogue",
          "type": "boolean"
        },
        "allow_unconfirmed_visual_material": {
          "title": "Allow Unconfirmed Visual Material",
          "type": "boolean"
        }
      },
      "required": [
        "allow_role_dialogue",
        "allow_real_person_role_mix",
        "allow_unconfirmed_visual_material",
        "allow_interview_audio",
        "allow_music",
        "allow_restricted_rights"
      ],
      "title": "ContentPolicy",
      "type": "object"
    },
    "CreativeBrief": {
      "additionalProperties": false,
      "properties": {
        "aspect_ratio": {
          "minLength": 3,
          "title": "Aspect Ratio",
          "type": "string"
        },
        "audience": {
          "minLength": 1,
          "title": "Audience",
          "type": "string"
        },
        "platform": {
          "minLength": 1,
          "title": "Platform",
          "type": "string"
        },
        "target_duration_seconds": {
          "exclusiveMinimum": 0,
          "title": "Target Duration Seconds",
          "type": "integer"
        },
        "theme": {
          "minLength": 1,
          "title": "Theme",
          "type": "string"
        },
        "tone": {
          "items": {
            "type": "string"
          },
          "title": "Tone",
          "type": "array"
        }
      },
      "required": [
        "theme",
        "audience",
        "platform",
        "target_duration_seconds",
        "aspect_ratio"
      ],
      "title": "CreativeBrief",
      "type": "object"
    },
    "EvidenceRef": {
      "additionalProperties": false,
      "properties": {
        "ref": {
          "minLength": 1,
          "title": "Ref",
          "type": "string"
        },
        "type": {
          "minLength": 1,
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "type",
        "ref"
      ],
      "title": "EvidenceRef",
      "type": "object"
    },
    "MediaKind": {
      "enum": [
        "video",
        "audio"
      ],
      "title": "MediaKind",
      "type": "string"
    },
    "ProposalAnalysisContext": {
      "additionalProperties": false,
      "properties": {
        "analysis_id": {
          "minLength": 1,
          "title": "Analysis Id",
          "type": "string"
        },
        "clip_id": {
          "minLength": 1,
          "title": "Clip Id",
          "type": "string"
        },
        "keyframe_refs": {
          "items": {
            "type": "string"
          },
          "title": "Keyframe Refs",
          "type": "array"
        },
        "material_type": {
          "title": "Material Type",
          "type": "string"
        },
        "original_audio_usability": {
          "title": "Original Audio Usability",
          "type": "string"
        },
        "pending_visual_fields": {
          "items": {
            "type": "string"
          },
          "title": "Pending Visual Fields",
          "type": "array"
        },
        "review_score": {
          "minimum": 0,
          "title": "Review Score",
          "type": "number"
        },
        "risk_flags": {
          "items": {
            "type": "string"
          },
          "title": "Risk Flags",
          "type": "array"
        },
        "source_id": {
          "minLength": 1,
          "title": "Source Id",
          "type": "string"
        },
        "transcript_refs": {
          "items": {
            "type": "string"
          },
          "title": "Transcript Refs",
          "type": "array"
        }
      },
      "required": [
        "analysis_id",
        "clip_id",
        "source_id",
        "material_type",
        "original_audio_usability",
        "review_score"
      ],
      "title": "ProposalAnalysisContext",
      "type": "object"
    },
    "ProposalClipContext": {
      "additionalProperties": false,
      "properties": {
        "clip_id": {
          "minLength": 1,
          "title": "Clip Id",
          "type": "string"
        },
        "duration_seconds": {
          "exclusiveMinimum": 0,
          "title": "Duration Seconds",
          "type": "number"
        },
        "end_seconds": {
          "exclusiveMinimum": 0,
          "title": "End Seconds",
          "type": "number"
        },
        "media_kind": {
          "$ref": "#/$defs/MediaKind"
        },
        "method": {
          "minLength": 1,
          "title": "Method",
          "type": "string"
        },
        "risk_flags": {
          "items": {
            "type": "string"
          },
          "title": "Risk Flags",
          "type": "array"
        },
        "source_id": {
          "minLength": 1,
          "title": "Source Id",
          "type": "string"
        },
        "source_location": {
          "minLength": 1,
          "title": "Source Location",
          "type": "string"
        },
        "start_seconds": {
          "minimum": 0,
          "title": "Start Seconds",
          "type": "number"
        }
      },
      "required": [
        "clip_id",
        "source_id",
        "source_location",
        "media_kind",
        "start_seconds",
        "end_seconds",
        "duration_seconds",
        "method"
      ],
      "title": "ProposalClipContext",
      "type": "object"
    },
    "ProposalClipScoreContext": {
      "additionalProperties": false,
      "properties": {
        "clip_id": {
          "minLength": 1,
          "title": "Clip Id",
          "type": "string"
        },
        "evidence_level": {
          "minLength": 1,
          "title": "Evidence Level",
          "type": "string"
        },
        "keep_recommendation": {
          "pattern": "^(keep|consider|review|drop)$",
          "title": "Keep Recommendation",
          "type": "string"
        },
        "overall_score": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Overall Score",
          "type": "number"
        },
        "reasons": {
          "items": {
            "type": "string"
          },
          "title": "Reasons",
          "type": "array"
        },
        "selection_tier": {
          "pattern": "^(hero|support|context|review|drop)$",
          "title": "Selection Tier",
          "type": "string"
        }
      },
      "required": [
        "clip_id",
        "overall_score",
        "selection_tier",
        "keep_recommendation",
        "evidence_level"
      ],
      "title": "ProposalClipScoreContext",
      "type": "object"
    },
    "ProposalSourceContext": {
      "additionalProperties": false,
      "properties": {
        "duration_seconds": {
          "exclusiveMinimum": 0,
          "title": "Duration Seconds",
          "type": "number"
        },
        "forbidden_by_user": {
          "title": "Forbidden By User",
          "type": "boolean"
        },
        "media_kind": {
          "$ref": "#/$defs/MediaKind"
        },
        "primary_location": {
          "minLength": 1,
          "title": "Primary Location",
          "type": "string"
        },
        "rights_status": {
          "title": "Rights Status",
          "type": "string"
        },
        "risk_flags": {
          "items": {
            "type": "string"
          },
          "title": "Risk Flags",
          "type": "array"
        },
        "source_id": {
          "minLength": 1,
          "title": "Source Id",
          "type": "string"
        },
        "source_type": {
          "title": "Source Type",
          "type": "string"
        }
      },
      "required": [
        "source_id",
        "primary_location",
        "media_kind",
        "source_type",
        "rights_status",
        "duration_seconds",
        "forbidden_by_user"
      ],
      "title": "ProposalSourceContext",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "analyses": {
      "items": {
        "$ref": "#/$defs/ProposalAnalysisContext"
      },
      "title": "Analyses",
      "type": "array"
    },
    "analysis_ref": {
      "minLength": 1,
      "title": "Analysis Ref",
      "type": "string"
    },
    "bgm_requirements": {
      "items": {
        "type": "string"
      },
      "title": "Bgm Requirements",
      "type": "array"
    },
    "blocked_capabilities": {
      "items": {
        "type": "string"
      },
      "title": "Blocked Capabilities",
      "type": "array"
    },
    "clip_scores": {
      "items": {
        "$ref": "#/$defs/ProposalClipScoreContext"
      },
      "title": "Clip Scores",
      "type": "array"
    },
    "clip_scores_fingerprint": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Clip Scores Fingerprint",
      "type": "string"
    },
    "clip_scores_ref": {
      "minLength": 1,
      "title": "Clip Scores Ref",
      "type": "string"
    },
    "clips": {
      "items": {
        "$ref": "#/$defs/ProposalClipContext"
      },
      "title": "Clips",
      "type": "array"
    },
    "clips_ref": {
      "minLength": 1,
      "title": "Clips Ref",
      "type": "string"
    },
    "constraints": {
      "items": {
        "type": "string"
      },
      "title": "Constraints",
      "type": "array"
    },
    "content_policy": {
      "$ref": "#/$defs/ContentPolicy"
    },
    "context_id": {
      "minLength": 1,
      "title": "Context Id",
      "type": "string"
    },
    "creative_brief": {
      "$ref": "#/$defs/CreativeBrief"
    },
    "evidence": {
      "items": {
        "$ref": "#/$defs/EvidenceRef"
      },
      "title": "Evidence",
      "type": "array"
    },
    "input_fingerprint": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Input Fingerprint",
      "type": "string"
    },
    "material_map_fingerprint": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Material Map Fingerprint",
      "type": "string"
    },
    "material_map_ref": {
      "minLength": 1,
      "title": "Material Map Ref",
      "type": "string"
    },
    "project_id": {
      "minLength": 1,
      "title": "Project Id",
      "type": "string"
    },
    "proposal_ids_required": {
      "items": {
        "type": "string"
      },
      "maxItems": 3,
      "minItems": 3,
      "title": "Proposal Ids Required",
      "type": "array"
    },
    "schema_version": {
      "default": "0.3",
      "title": "Schema Version",
      "type": "string"
    },
    "sources": {
      "items": {
        "$ref": "#/$defs/ProposalSourceContext"
      },
      "title": "Sources",
      "type": "array"
    },
    "sources_ref": {
      "minLength": 1,
      "title": "Sources Ref",
      "type": "string"
    }
  },
  "required": [
    "context_id",
    "project_id",
    "material_map_ref",
    "material_map_fingerprint",
    "sources_ref",
    "clips_ref",
    "analysis_ref",
    "clip_scores_ref",
    "clip_scores_fingerprint",
    "input_fingerprint",
    "creative_brief",
    "content_policy",
    "proposal_ids_required"
  ],
  "title": "ProposalContext",
  "type": "object"
}
