{
  "$defs": {
    "GoalAdvantage": {
      "additionalProperties": false,
      "properties": {
        "confidence": {
          "maximum": 1,
          "minimum": 0,
          "title": "Confidence",
          "type": "number"
        },
        "goal": {
          "pattern": "^(fast_hook|emotional_depth|information_clarity|voice_first|text_light|strong_ending|platform_delivery)$",
          "title": "Goal",
          "type": "string"
        },
        "leading_version_ids": {
          "items": {
            "type": "string"
          },
          "title": "Leading Version Ids",
          "type": "array"
        },
        "rationale": {
          "minLength": 1,
          "title": "Rationale",
          "type": "string"
        },
        "status": {
          "pattern": "^(supported|tie|unavailable)$",
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "goal",
        "status",
        "rationale",
        "confidence"
      ],
      "title": "GoalAdvantage",
      "type": "object"
    },
    "ReviewedVersion": {
      "additionalProperties": false,
      "properties": {
        "artifact_fingerprint": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Artifact Fingerprint",
          "type": "string"
        },
        "artifact_ref": {
          "minLength": 1,
          "title": "Artifact Ref",
          "type": "string"
        },
        "assessments": {
          "items": {
            "$ref": "#/$defs/VersionDomainAssessment"
          },
          "maxItems": 7,
          "minItems": 7,
          "title": "Assessments",
          "type": "array"
        },
        "current": {
          "title": "Current",
          "type": "boolean"
        },
        "duration_seconds": {
          "exclusiveMinimum": 0,
          "title": "Duration Seconds",
          "type": "number"
        },
        "evidence_level": {
          "pattern": "^(rendered_media|timeline_candidate|plan_only)$",
          "title": "Evidence Level",
          "type": "string"
        },
        "media_valid": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Media Valid"
        },
        "segment_count": {
          "minimum": 1,
          "title": "Segment Count",
          "type": "integer"
        },
        "unresolved_domains": {
          "items": {
            "type": "string"
          },
          "title": "Unresolved Domains",
          "type": "array"
        },
        "version_id": {
          "minLength": 1,
          "title": "Version Id",
          "type": "string"
        },
        "version_kind": {
          "pattern": "^(canonical_timeline|rendered_second_cut|revision_candidate)$",
          "title": "Version Kind",
          "type": "string"
        },
        "warnings": {
          "items": {
            "type": "string"
          },
          "title": "Warnings",
          "type": "array"
        }
      },
      "required": [
        "version_id",
        "version_kind",
        "artifact_ref",
        "artifact_fingerprint",
        "evidence_level",
        "duration_seconds",
        "segment_count",
        "current",
        "assessments"
      ],
      "title": "ReviewedVersion",
      "type": "object"
    },
    "VersionDomainAssessment": {
      "additionalProperties": false,
      "properties": {
        "confidence": {
          "maximum": 1,
          "minimum": 0,
          "title": "Confidence",
          "type": "number"
        },
        "domain": {
          "pattern": "^(hook|emotional_arc|information_density|bgm_conflict|text_burden|ending_strength|platform_fit)$",
          "title": "Domain",
          "type": "string"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "finding": {
          "minLength": 1,
          "title": "Finding",
          "type": "string"
        },
        "limitations": {
          "items": {
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        },
        "score": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Score"
        },
        "status": {
          "pattern": "^(known|partial|unavailable)$",
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "domain",
        "status",
        "confidence",
        "finding"
      ],
      "title": "VersionDomainAssessment",
      "type": "object"
    },
    "VersionPairComparison": {
      "additionalProperties": false,
      "properties": {
        "comparable_domains": {
          "items": {
            "type": "string"
          },
          "title": "Comparable Domains",
          "type": "array"
        },
        "left_advantages": {
          "items": {
            "type": "string"
          },
          "title": "Left Advantages",
          "type": "array"
        },
        "left_version_id": {
          "title": "Left Version Id",
          "type": "string"
        },
        "right_advantages": {
          "items": {
            "type": "string"
          },
          "title": "Right Advantages",
          "type": "array"
        },
        "right_version_id": {
          "title": "Right Version Id",
          "type": "string"
        },
        "tradeoff_summary": {
          "minLength": 1,
          "title": "Tradeoff Summary",
          "type": "string"
        },
        "unresolved_domains": {
          "items": {
            "type": "string"
          },
          "title": "Unresolved Domains",
          "type": "array"
        }
      },
      "required": [
        "left_version_id",
        "right_version_id",
        "tradeoff_summary"
      ],
      "title": "VersionPairComparison",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "automatic_music_selection": {
      "default": false,
      "title": "Automatic Music Selection",
      "type": "boolean"
    },
    "automatic_version_selection": {
      "default": false,
      "title": "Automatic Version Selection",
      "type": "boolean"
    },
    "canonical_timeline_mutated": {
      "default": false,
      "title": "Canonical Timeline Mutated",
      "type": "boolean"
    },
    "comparison_is_aesthetic_acceptance": {
      "default": false,
      "title": "Comparison Is Aesthetic Acceptance",
      "type": "boolean"
    },
    "goal_advantages": {
      "items": {
        "$ref": "#/$defs/GoalAdvantage"
      },
      "maxItems": 7,
      "minItems": 7,
      "title": "Goal Advantages",
      "type": "array"
    },
    "media_rendered": {
      "default": false,
      "title": "Media Rendered",
      "type": "boolean"
    },
    "model_call_performed_by_cli": {
      "default": false,
      "title": "Model Call Performed By Cli",
      "type": "boolean"
    },
    "network_performed": {
      "default": false,
      "title": "Network Performed",
      "type": "boolean"
    },
    "overall_winner_id": {
      "default": null,
      "title": "Overall Winner Id",
      "type": "null"
    },
    "pairwise_comparisons": {
      "items": {
        "$ref": "#/$defs/VersionPairComparison"
      },
      "minItems": 1,
      "title": "Pairwise Comparisons",
      "type": "array"
    },
    "project_id": {
      "title": "Project Id",
      "type": "string"
    },
    "review_id": {
      "title": "Review Id",
      "type": "string"
    },
    "schema_version": {
      "default": "0.3",
      "title": "Schema Version",
      "type": "string"
    },
    "selection_required": {
      "default": true,
      "title": "Selection Required",
      "type": "boolean"
    },
    "status": {
      "pattern": "^(ready|warning|blocked)$",
      "title": "Status",
      "type": "string"
    },
    "version_count": {
      "minimum": 2,
      "title": "Version Count",
      "type": "integer"
    },
    "versions": {
      "items": {
        "$ref": "#/$defs/ReviewedVersion"
      },
      "minItems": 2,
      "title": "Versions",
      "type": "array"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "review_id",
    "project_id",
    "status",
    "version_count",
    "versions",
    "pairwise_comparisons",
    "goal_advantages"
  ],
  "title": "VersionReview",
  "type": "object"
}
