{
  "$defs": {
    "EditGuidanceAction": {
      "additionalProperties": false,
      "properties": {
        "action_id": {
          "minLength": 1,
          "title": "Action Id",
          "type": "string"
        },
        "category": {
          "pattern": "^(subtitle|transition|pause|ducking|phrase|cut_review|ending|source_risk|qc_repair|handoff)$",
          "title": "Category",
          "type": "string"
        },
        "edits_applied": {
          "default": false,
          "title": "Edits Applied",
          "type": "boolean"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "manual_only": {
          "default": true,
          "title": "Manual Only",
          "type": "boolean"
        },
        "order": {
          "minimum": 1,
          "title": "Order",
          "type": "integer"
        },
        "priority": {
          "pattern": "^(low|medium|high)$",
          "title": "Priority",
          "type": "string"
        },
        "rationale": {
          "minLength": 1,
          "title": "Rationale",
          "type": "string"
        },
        "recommendation": {
          "minLength": 1,
          "title": "Recommendation",
          "type": "string"
        },
        "timeline_end": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Timeline End"
        },
        "timeline_start": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Timeline Start"
        }
      },
      "required": [
        "action_id",
        "order",
        "category",
        "priority",
        "recommendation",
        "rationale"
      ],
      "title": "EditGuidanceAction",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "action_count": {
      "minimum": 0,
      "title": "Action Count",
      "type": "integer"
    },
    "actions": {
      "items": {
        "$ref": "#/$defs/EditGuidanceAction"
      },
      "title": "Actions",
      "type": "array"
    },
    "automatic_music_selection": {
      "default": false,
      "title": "Automatic Music Selection",
      "type": "boolean"
    },
    "bgm_rhythm_intelligence_fingerprint": {
      "anyOf": [
        {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Bgm Rhythm Intelligence Fingerprint"
    },
    "edit_guidance_id": {
      "minLength": 1,
      "title": "Edit Guidance Id",
      "type": "string"
    },
    "edit_points_moved": {
      "default": false,
      "title": "Edit Points Moved",
      "type": "boolean"
    },
    "high_priority_count": {
      "minimum": 0,
      "title": "High Priority Count",
      "type": "integer"
    },
    "manual_only": {
      "default": true,
      "title": "Manual Only",
      "type": "boolean"
    },
    "media_rendered": {
      "default": false,
      "title": "Media Rendered",
      "type": "boolean"
    },
    "model_call_performed_by_cli": {
      "default": false,
      "title": "Model Call Performed By Cli",
      "type": "boolean"
    },
    "network_performed": {
      "default": false,
      "title": "Network Performed",
      "type": "boolean"
    },
    "project_id": {
      "minLength": 1,
      "title": "Project Id",
      "type": "string"
    },
    "rhythm_media_qc_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Rhythm Media Qc Id"
    },
    "rhythm_plan_fingerprint": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Rhythm Plan Fingerprint",
      "type": "string"
    },
    "rhythm_plan_id": {
      "minLength": 1,
      "title": "Rhythm Plan Id",
      "type": "string"
    },
    "schema_version": {
      "default": "0.3",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "pattern": "^(passed|warning|blocked)$",
      "title": "Status",
      "type": "string"
    },
    "timeline_fingerprint": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Timeline Fingerprint",
      "type": "string"
    },
    "timeline_id": {
      "minLength": 1,
      "title": "Timeline Id",
      "type": "string"
    },
    "timeline_mutated": {
      "default": false,
      "title": "Timeline Mutated",
      "type": "boolean"
    }
  },
  "required": [
    "edit_guidance_id",
    "project_id",
    "rhythm_plan_id",
    "rhythm_plan_fingerprint",
    "timeline_id",
    "timeline_fingerprint",
    "action_count",
    "high_priority_count",
    "status"
  ],
  "title": "EditGuidanceReport",
  "type": "object"
}
