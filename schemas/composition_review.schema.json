{
  "$defs": {
    "CompositionFrameReview": {
      "additionalProperties": false,
      "properties": {
        "branding_intrusion": {
          "maximum": 1,
          "minimum": 0,
          "title": "Branding Intrusion",
          "type": "number"
        },
        "confidence": {
          "maximum": 1,
          "minimum": 0,
          "title": "Confidence",
          "type": "number"
        },
        "crop_safety": {
          "pattern": "^(safe|conditional|unsafe)$",
          "title": "Crop Safety",
          "type": "string"
        },
        "dead_space": {
          "maximum": 1,
          "minimum": 0,
          "title": "Dead Space",
          "type": "number"
        },
        "observations": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Observations",
          "type": "array"
        },
        "performer_box": {
          "anyOf": [
            {
              "$ref": "#/$defs/NormalizedBox"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "performer_prominence": {
          "maximum": 1,
          "minimum": 0,
          "title": "Performer Prominence",
          "type": "number"
        },
        "protected_boxes": {
          "items": {
            "$ref": "#/$defs/NormalizedBox"
          },
          "title": "Protected Boxes",
          "type": "array"
        },
        "sample_id": {
          "pattern": "^sample_[0-9]{2}$",
          "title": "Sample Id",
          "type": "string"
        },
        "timestamp_seconds": {
          "minimum": 0,
          "title": "Timestamp Seconds",
          "type": "number"
        },
        "usability": {
          "pattern": "^(usable|reframe_required|reject)$",
          "title": "Usability",
          "type": "string"
        }
      },
      "required": [
        "sample_id",
        "timestamp_seconds",
        "performer_prominence",
        "branding_intrusion",
        "dead_space",
        "crop_safety",
        "usability",
        "observations",
        "confidence"
      ],
      "title": "CompositionFrameReview",
      "type": "object"
    },
    "NormalizedBox": {
      "additionalProperties": false,
      "properties": {
        "height": {
          "exclusiveMinimum": 0,
          "maximum": 1,
          "title": "Height",
          "type": "number"
        },
        "width": {
          "exclusiveMinimum": 0,
          "maximum": 1,
          "title": "Width",
          "type": "number"
        },
        "x": {
          "maximum": 1,
          "minimum": 0,
          "title": "X",
          "type": "number"
        },
        "y": {
          "maximum": 1,
          "minimum": 0,
          "title": "Y",
          "type": "number"
        }
      },
      "required": [
        "x",
        "y",
        "width",
        "height"
      ],
      "title": "NormalizedBox",
      "type": "object"
    },
    "PixelCropBox": {
      "additionalProperties": false,
      "properties": {
        "height": {
          "exclusiveMinimum": 1,
          "title": "Height",
          "type": "integer"
        },
        "width": {
          "exclusiveMinimum": 1,
          "title": "Width",
          "type": "integer"
        },
        "x": {
          "minimum": 0,
          "title": "X",
          "type": "integer"
        },
        "y": {
          "minimum": 0,
          "title": "Y",
          "type": "integer"
        }
      },
      "required": [
        "x",
        "y",
        "width",
        "height"
      ],
      "title": "PixelCropBox",
      "type": "object"
    },
    "ReframeCandidate": {
      "additionalProperties": false,
      "properties": {
        "applicable_sample_ids": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Applicable Sample Ids",
          "type": "array"
        },
        "applied": {
          "default": false,
          "title": "Applied",
          "type": "boolean"
        },
        "benefits": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Benefits",
          "type": "array"
        },
        "candidate_id": {
          "pattern": "^reframe_[a-z0-9_]+$",
          "title": "Candidate Id",
          "type": "string"
        },
        "confidence": {
          "maximum": 1,
          "minimum": 0,
          "title": "Confidence",
          "type": "number"
        },
        "crop_box": {
          "$ref": "#/$defs/PixelCropBox"
        },
        "media_rendered": {
          "default": false,
          "title": "Media Rendered",
          "type": "boolean"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "protected_region_policy": {
          "minLength": 1,
          "title": "Protected Region Policy",
          "type": "string"
        },
        "reject_reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reject Reason"
        },
        "risks": {
          "items": {
            "type": "string"
          },
          "title": "Risks",
          "type": "array"
        },
        "source_height": {
          "exclusiveMinimum": 0,
          "title": "Source Height",
          "type": "integer"
        },
        "source_width": {
          "exclusiveMinimum": 0,
          "title": "Source Width",
          "type": "integer"
        },
        "status": {
          "pattern": "^(candidate|conditional|rejected)$",
          "title": "Status",
          "type": "string"
        },
        "target_aspect_ratio": {
          "pattern": "^[1-9][0-9]*:[1-9][0-9]*$",
          "title": "Target Aspect Ratio",
          "type": "string"
        }
      },
      "required": [
        "candidate_id",
        "name",
        "status",
        "source_width",
        "source_height",
        "crop_box",
        "target_aspect_ratio",
        "applicable_sample_ids",
        "protected_region_policy",
        "benefits",
        "confidence"
      ],
      "title": "ReframeCandidate",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "aesthetic_status": {
      "pattern": "^(usable|needs_reframe|unpublishable)$",
      "title": "Aesthetic Status",
      "type": "string"
    },
    "composition_evidence_id": {
      "minLength": 1,
      "title": "Composition Evidence Id",
      "type": "string"
    },
    "conclusions": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "title": "Conclusions",
      "type": "array"
    },
    "contact_sheet_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Contact Sheet Hash",
      "type": "string"
    },
    "contact_sheet_ref": {
      "minLength": 1,
      "title": "Contact Sheet Ref",
      "type": "string"
    },
    "crop_applied": {
      "default": false,
      "title": "Crop Applied",
      "type": "boolean"
    },
    "final_export_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Final Export Hash",
      "type": "string"
    },
    "final_export_ref": {
      "minLength": 1,
      "title": "Final Export Ref",
      "type": "string"
    },
    "frame_reviews": {
      "items": {
        "$ref": "#/$defs/CompositionFrameReview"
      },
      "minItems": 1,
      "title": "Frame Reviews",
      "type": "array"
    },
    "image_generation_or_editing_used": {
      "default": false,
      "title": "Image Generation Or Editing Used",
      "type": "boolean"
    },
    "media_rendered": {
      "default": false,
      "title": "Media Rendered",
      "type": "boolean"
    },
    "method": {
      "minLength": 1,
      "title": "Method",
      "type": "string"
    },
    "method_version": {
      "minLength": 1,
      "title": "Method Version",
      "type": "string"
    },
    "model_call_performed_by_cli": {
      "default": false,
      "title": "Model Call Performed By Cli",
      "type": "boolean"
    },
    "network_performed": {
      "default": false,
      "title": "Network Performed",
      "type": "boolean"
    },
    "project_id": {
      "minLength": 1,
      "title": "Project Id",
      "type": "string"
    },
    "recommended_candidate_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Recommended Candidate Id"
    },
    "reframe_candidates": {
      "items": {
        "$ref": "#/$defs/ReframeCandidate"
      },
      "minItems": 1,
      "title": "Reframe Candidates",
      "type": "array"
    },
    "review_id": {
      "minLength": 1,
      "title": "Review Id",
      "type": "string"
    },
    "reviewed_only_supplied_frames": {
      "default": true,
      "title": "Reviewed Only Supplied Frames",
      "type": "boolean"
    },
    "schema_version": {
      "default": "0.3",
      "title": "Schema Version",
      "type": "string"
    },
    "timeline_fingerprint": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Timeline Fingerprint",
      "type": "string"
    },
    "timeline_id": {
      "minLength": 1,
      "title": "Timeline Id",
      "type": "string"
    },
    "timeline_mutated": {
      "default": false,
      "title": "Timeline Mutated",
      "type": "boolean"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "review_id",
    "project_id",
    "composition_evidence_id",
    "timeline_id",
    "timeline_fingerprint",
    "final_export_ref",
    "final_export_hash",
    "contact_sheet_ref",
    "contact_sheet_hash",
    "method",
    "method_version",
    "aesthetic_status",
    "frame_reviews",
    "reframe_candidates",
    "conclusions"
  ],
  "title": "CompositionReview",
  "type": "object"
}
