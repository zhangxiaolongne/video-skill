{
  "$defs": {
    "PublishabilityIssue": {
      "additionalProperties": false,
      "properties": {
        "detail": {
          "title": "Detail",
          "type": "string"
        },
        "disposition": {
          "enum": [
            "blocks_use",
            "blocks_publish",
            "requires_refinement",
            "evidence_gap"
          ],
          "title": "Disposition",
          "type": "string"
        },
        "domain": {
          "enum": [
            "media",
            "technical",
            "hook",
            "emotion",
            "information",
            "bgm_voice",
            "text",
            "ending",
            "transitions",
            "composition",
            "platform",
            "nle",
            "evidence"
          ],
          "title": "Domain",
          "type": "string"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "issue_id": {
          "title": "Issue Id",
          "type": "string"
        },
        "next_action": {
          "title": "Next Action",
          "type": "string"
        },
        "severity": {
          "enum": [
            "info",
            "low",
            "medium",
            "high",
            "critical"
          ],
          "title": "Severity",
          "type": "string"
        }
      },
      "required": [
        "issue_id",
        "domain",
        "severity",
        "disposition",
        "detail",
        "next_action"
      ],
      "title": "PublishabilityIssue",
      "type": "object"
    },
    "VersionPublishability": {
      "additionalProperties": false,
      "properties": {
        "aesthetic_review_present": {
          "title": "Aesthetic Review Present",
          "type": "boolean"
        },
        "blocking_issue_count": {
          "minimum": 0,
          "title": "Blocking Issue Count",
          "type": "integer"
        },
        "confidence": {
          "maximum": 1,
          "minimum": 0,
          "title": "Confidence",
          "type": "number"
        },
        "evidence_gap_count": {
          "minimum": 0,
          "title": "Evidence Gap Count",
          "type": "integer"
        },
        "evidence_level": {
          "title": "Evidence Level",
          "type": "string"
        },
        "issue_count": {
          "minimum": 0,
          "title": "Issue Count",
          "type": "integer"
        },
        "issues": {
          "items": {
            "$ref": "#/$defs/PublishabilityIssue"
          },
          "title": "Issues",
          "type": "array"
        },
        "media_present": {
          "title": "Media Present",
          "type": "boolean"
        },
        "next_commands": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Next Commands",
          "type": "array"
        },
        "ready_for_preview": {
          "title": "Ready For Preview",
          "type": "boolean"
        },
        "ready_for_publish": {
          "title": "Ready For Publish",
          "type": "boolean"
        },
        "refinement_issue_count": {
          "minimum": 0,
          "title": "Refinement Issue Count",
          "type": "integer"
        },
        "satisfied_requirements": {
          "items": {
            "type": "string"
          },
          "title": "Satisfied Requirements",
          "type": "array"
        },
        "technical_valid": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Technical Valid"
        },
        "tier": {
          "enum": [
            "previewable",
            "publishable",
            "manual_refinement_required",
            "unusable"
          ],
          "title": "Tier",
          "type": "string"
        },
        "version_id": {
          "title": "Version Id",
          "type": "string"
        },
        "version_kind": {
          "title": "Version Kind",
          "type": "string"
        }
      },
      "required": [
        "version_id",
        "version_kind",
        "evidence_level",
        "tier",
        "media_present",
        "aesthetic_review_present",
        "ready_for_preview",
        "ready_for_publish",
        "issue_count",
        "blocking_issue_count",
        "refinement_issue_count",
        "evidence_gap_count",
        "next_commands",
        "confidence"
      ],
      "title": "VersionPublishability",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "automatic_music_selection": {
      "default": false,
      "title": "Automatic Music Selection",
      "type": "boolean"
    },
    "automatic_version_selection": {
      "default": false,
      "title": "Automatic Version Selection",
      "type": "boolean"
    },
    "canonical_timeline_mutated": {
      "default": false,
      "title": "Canonical Timeline Mutated",
      "type": "boolean"
    },
    "explicit_selection_required": {
      "default": true,
      "title": "Explicit Selection Required",
      "type": "boolean"
    },
    "highest_available_tier": {
      "enum": [
        "previewable",
        "publishable",
        "manual_refinement_required",
        "unusable"
      ],
      "title": "Highest Available Tier",
      "type": "string"
    },
    "highest_tier_version_ids": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "title": "Highest Tier Version Ids",
      "type": "array"
    },
    "media_rendered": {
      "default": false,
      "title": "Media Rendered",
      "type": "boolean"
    },
    "model_call_performed_by_cli": {
      "default": false,
      "title": "Model Call Performed By Cli",
      "type": "boolean"
    },
    "network_performed": {
      "default": false,
      "title": "Network Performed",
      "type": "boolean"
    },
    "project_id": {
      "title": "Project Id",
      "type": "string"
    },
    "report_id": {
      "title": "Report Id",
      "type": "string"
    },
    "schema_version": {
      "default": "0.3",
      "title": "Schema Version",
      "type": "string"
    },
    "selected_version_id": {
      "default": null,
      "title": "Selected Version Id",
      "type": "null"
    },
    "status": {
      "enum": [
        "ready",
        "warning",
        "blocked"
      ],
      "title": "Status",
      "type": "string"
    },
    "tier_counts": {
      "additionalProperties": {
        "type": "integer"
      },
      "title": "Tier Counts",
      "type": "object"
    },
    "version_count": {
      "minimum": 2,
      "title": "Version Count",
      "type": "integer"
    },
    "version_review_fingerprint": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Version Review Fingerprint",
      "type": "string"
    },
    "version_review_id": {
      "title": "Version Review Id",
      "type": "string"
    },
    "versions": {
      "items": {
        "$ref": "#/$defs/VersionPublishability"
      },
      "minItems": 2,
      "title": "Versions",
      "type": "array"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "report_id",
    "project_id",
    "status",
    "version_review_id",
    "version_review_fingerprint",
    "version_count",
    "tier_counts",
    "highest_available_tier",
    "highest_tier_version_ids",
    "versions"
  ],
  "title": "PublishabilityReport",
  "type": "object"
}
