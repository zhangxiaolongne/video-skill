{
  "$defs": {
    "RhythmAuditDomain": {
      "additionalProperties": false,
      "properties": {
        "domain_id": {
          "minLength": 1,
          "title": "Domain Id",
          "type": "string"
        },
        "issues": {
          "items": {
            "$ref": "#/$defs/RhythmIssue"
          },
          "title": "Issues",
          "type": "array"
        },
        "metrics": {
          "items": {
            "$ref": "#/$defs/RhythmProfileMetric"
          },
          "title": "Metrics",
          "type": "array"
        },
        "status": {
          "pattern": "^(passed|warning|blocked|unavailable)$",
          "title": "Status",
          "type": "string"
        },
        "summary": {
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        }
      },
      "required": [
        "domain_id",
        "status",
        "summary"
      ],
      "title": "RhythmAuditDomain",
      "type": "object"
    },
    "RhythmIssue": {
      "additionalProperties": false,
      "properties": {
        "detail": {
          "minLength": 1,
          "title": "Detail",
          "type": "string"
        },
        "domain": {
          "pattern": "^(timeline|bgm|compatibility|intent|cut_cue|transition|text|ducking_silence|ending|agent_candidate)$",
          "title": "Domain",
          "type": "string"
        },
        "issue_id": {
          "minLength": 1,
          "title": "Issue Id",
          "type": "string"
        },
        "next_action": {
          "minLength": 1,
          "title": "Next Action",
          "type": "string"
        },
        "severity": {
          "pattern": "^(info|warning|error)$",
          "title": "Severity",
          "type": "string"
        }
      },
      "required": [
        "issue_id",
        "domain",
        "severity",
        "detail",
        "next_action"
      ],
      "title": "RhythmIssue",
      "type": "object"
    },
    "RhythmProfileMetric": {
      "additionalProperties": false,
      "properties": {
        "detail": {
          "minLength": 1,
          "title": "Detail",
          "type": "string"
        },
        "label": {
          "minLength": 1,
          "title": "Label",
          "type": "string"
        },
        "metric_id": {
          "minLength": 1,
          "title": "Metric Id",
          "type": "string"
        },
        "status": {
          "pattern": "^(available|unavailable|warning)$",
          "title": "Status",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "string"
            },
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        }
      },
      "required": [
        "metric_id",
        "label",
        "status",
        "detail"
      ],
      "title": "RhythmProfileMetric",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "audio_expectation_qc": {
      "$ref": "#/$defs/RhythmAuditDomain"
    },
    "automatic_music_selection": {
      "default": false,
      "title": "Automatic Music Selection",
      "type": "boolean"
    },
    "bgm_freshness": {
      "$ref": "#/$defs/RhythmAuditDomain"
    },
    "ducking_render_qc": {
      "$ref": "#/$defs/RhythmAuditDomain"
    },
    "edit_points_moved": {
      "default": false,
      "title": "Edit Points Moved",
      "type": "boolean"
    },
    "ending_render_qc": {
      "$ref": "#/$defs/RhythmAuditDomain"
    },
    "error_count": {
      "minimum": 0,
      "title": "Error Count",
      "type": "integer"
    },
    "final_duration_qc": {
      "$ref": "#/$defs/RhythmAuditDomain"
    },
    "final_export_binding": {
      "$ref": "#/$defs/RhythmAuditDomain"
    },
    "final_export_rendered_by_qc": {
      "default": false,
      "title": "Final Export Rendered By Qc",
      "type": "boolean"
    },
    "issue_count": {
      "minimum": 0,
      "title": "Issue Count",
      "type": "integer"
    },
    "media_qc_summary": {
      "$ref": "#/$defs/RhythmAuditDomain"
    },
    "model_call_performed_by_cli": {
      "default": false,
      "title": "Model Call Performed By Cli",
      "type": "boolean"
    },
    "network_performed": {
      "default": false,
      "title": "Network Performed",
      "type": "boolean"
    },
    "preview_binding": {
      "$ref": "#/$defs/RhythmAuditDomain"
    },
    "preview_duration_qc": {
      "$ref": "#/$defs/RhythmAuditDomain"
    },
    "preview_rendered_by_qc": {
      "default": false,
      "title": "Preview Rendered By Qc",
      "type": "boolean"
    },
    "project_id": {
      "minLength": 1,
      "title": "Project Id",
      "type": "string"
    },
    "rhythm_plan_fingerprint": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Rhythm Plan Fingerprint",
      "type": "string"
    },
    "rhythm_plan_id": {
      "minLength": 1,
      "title": "Rhythm Plan Id",
      "type": "string"
    },
    "rhythm_qc_id": {
      "minLength": 1,
      "title": "Rhythm Qc Id",
      "type": "string"
    },
    "schema_version": {
      "default": "0.3",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "pattern": "^(passed|warning|blocked)$",
      "title": "Status",
      "type": "string"
    },
    "timeline_freshness": {
      "$ref": "#/$defs/RhythmAuditDomain"
    },
    "timeline_id": {
      "minLength": 1,
      "title": "Timeline Id",
      "type": "string"
    },
    "warning_count": {
      "minimum": 0,
      "title": "Warning Count",
      "type": "integer"
    }
  },
  "required": [
    "rhythm_qc_id",
    "project_id",
    "rhythm_plan_id",
    "rhythm_plan_fingerprint",
    "timeline_id",
    "preview_binding",
    "final_export_binding",
    "timeline_freshness",
    "bgm_freshness",
    "preview_duration_qc",
    "final_duration_qc",
    "audio_expectation_qc",
    "ducking_render_qc",
    "ending_render_qc",
    "media_qc_summary",
    "issue_count",
    "warning_count",
    "error_count",
    "status"
  ],
  "title": "RhythmMediaQcReport",
  "type": "object"
}
