  "required": [
    "request_id",
    "project_id",
    "status",
    "proposal_context_ref",
    "text_model_gate_ref",
    "proposal_context_fingerprint",
    "request_fingerprint",
    "target_schema_ref",
    "target_schema_name",
    "required_proposal_ids",
