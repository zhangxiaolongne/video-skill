{
  "$defs": {
    "DurationOption": {
      "additionalProperties": false,
      "properties": {
        "duration_ratio_to_video": {
          "minimum": 0,
          "title": "Duration Ratio To Video",
          "type": "number"
        },
        "duration_seconds": {
          "exclusiveMinimum": 0,
          "title": "Duration Seconds",
          "type": "number"
        },
        "editorial_purpose": {
          "minLength": 1,
          "title": "Editorial Purpose",
          "type": "string"
        },
        "label": {
          "minLength": 1,
          "title": "Label",
          "type": "string"
        },
        "option_id": {
          "pattern": "^(short_cut|standard_cut|extended_cut|user_specified)$",
          "title": "Option Id",
          "type": "string"
        },
        "primary_platform_fit": {
          "items": {
            "type": "string"
          },
          "title": "Primary Platform Fit",
          "type": "array"
        },
        "rationale": {
          "items": {
            "type": "string"
          },
          "title": "Rationale",
          "type": "array"
        },
        "risks": {
          "items": {
            "type": "string"
          },
          "title": "Risks",
          "type": "array"
        }
      },
      "required": [
        "option_id",
        "label",
        "duration_seconds",
        "duration_ratio_to_video",
        "editorial_purpose"
      ],
      "title": "DurationOption",
      "type": "object"
    },
    "EditBriefEvidenceSummary": {
      "additionalProperties": false,
      "properties": {
        "analysis_record_count": {
          "minimum": 0,
          "title": "Analysis Record Count",
          "type": "integer"
        },
        "audio_source_count": {
          "minimum": 0,
          "title": "Audio Source Count",
          "type": "integer"
        },
        "clip_count": {
          "minimum": 0,
          "title": "Clip Count",
          "type": "integer"
        },
        "content_density": {
          "pattern": "^(unknown|low|medium|high)$",
          "title": "Content Density",
          "type": "string"
        },
        "evidence_level": {
          "pattern": "^(sources_only|clips_available|analysis_available)$",
          "title": "Evidence Level",
          "type": "string"
        },
        "keyframe_backed_analysis_count": {
          "minimum": 0,
          "title": "Keyframe Backed Analysis Count",
          "type": "integer"
        },
        "source_count": {
          "minimum": 0,
          "title": "Source Count",
          "type": "integer"
        },
        "stage_or_music_source_count": {
          "minimum": 0,
          "title": "Stage Or Music Source Count",
          "type": "integer"
        },
        "total_audio_duration_seconds": {
          "minimum": 0,
          "title": "Total Audio Duration Seconds",
          "type": "number"
        },
        "total_video_duration_seconds": {
          "minimum": 0,
          "title": "Total Video Duration Seconds",
          "type": "number"
        },
        "transcript_backed_analysis_count": {
          "minimum": 0,
          "title": "Transcript Backed Analysis Count",
          "type": "integer"
        },
        "video_clip_count": {
          "minimum": 0,
          "title": "Video Clip Count",
          "type": "integer"
        },
        "video_source_count": {
          "minimum": 0,
          "title": "Video Source Count",
          "type": "integer"
        }
      },
      "required": [
        "source_count",
        "video_source_count",
        "audio_source_count",
        "total_video_duration_seconds",
        "total_audio_duration_seconds",
        "clip_count",
        "video_clip_count",
        "analysis_record_count",
        "transcript_backed_analysis_count",
        "keyframe_backed_analysis_count",
        "stage_or_music_source_count",
        "content_density",
        "evidence_level"
      ],
      "title": "EditBriefEvidenceSummary",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "analysis_ledger_fingerprint": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Analysis Ledger Fingerprint"
    },
    "analysis_ledger_ref": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Analysis Ledger Ref"
    },
    "artifact_refs": {
      "items": {
        "type": "string"
      },
      "title": "Artifact Refs",
      "type": "array"
    },
    "artist_name": {
      "minLength": 1,
      "title": "Artist Name",
      "type": "string"
    },
    "aspect_ratio": {
      "minLength": 1,
      "title": "Aspect Ratio",
      "type": "string"
    },
    "audience": {
      "minLength": 1,
      "title": "Audience",
      "type": "string"
    },
    "automatic_bgm_fit": {
      "default": false,
      "title": "Automatic Bgm Fit",
      "type": "boolean"
    },
    "automatic_music_selection": {
      "default": false,
      "title": "Automatic Music Selection",
      "type": "boolean"
    },
    "clip_ledger_fingerprint": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Clip Ledger Fingerprint"
    },
    "clip_ledger_ref": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Clip Ledger Ref"
    },
    "commands_executed": {
      "default": false,
      "title": "Commands Executed",
      "type": "boolean"
    },
    "duration_options": {
      "items": {
        "$ref": "#/$defs/DurationOption"
      },
      "minItems": 1,
      "title": "Duration Options",
      "type": "array"
    },
    "duration_source": {
      "pattern": "^(user_specified|system_recommended)$",
      "title": "Duration Source",
      "type": "string"
    },
    "edit_brief_id": {
      "minLength": 1,
      "title": "Edit Brief Id",
      "type": "string"
    },
    "edit_intent": {
      "items": {
        "type": "string"
      },
      "title": "Edit Intent",
      "type": "array"
    },
    "edit_points_moved": {
      "default": false,
      "title": "Edit Points Moved",
      "type": "boolean"
    },
    "evidence_summary": {
      "$ref": "#/$defs/EditBriefEvidenceSummary"
    },
    "forbidden_capability_flags": {
      "additionalProperties": {
        "type": "boolean"
      },
      "title": "Forbidden Capability Flags",
      "type": "object"
    },
    "image_generation_or_editing_used": {
      "default": false,
      "title": "Image Generation Or Editing Used",
      "type": "boolean"
    },
    "media_rendered": {
      "default": false,
      "title": "Media Rendered",
      "type": "boolean"
    },
    "model_call_performed_by_cli": {
      "default": false,
      "title": "Model Call Performed By Cli",
      "type": "boolean"
    },
    "network_performed": {
      "default": false,
      "title": "Network Performed",
      "type": "boolean"
    },
    "next_actions": {
      "items": {
        "type": "string"
      },
      "title": "Next Actions",
      "type": "array"
    },
    "pacing_strategy": {
      "items": {
        "type": "string"
      },
      "title": "Pacing Strategy",
      "type": "array"
    },
    "project_id": {
      "minLength": 1,
      "title": "Project Id",
      "type": "string"
    },
    "requested_duration_seconds": {
      "anyOf": [
        {
          "exclusiveMinimum": 0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Requested Duration Seconds"
    },
    "risk_notes": {
      "items": {
        "type": "string"
      },
      "title": "Risk Notes",
      "type": "array"
    },
    "schema_version": {
      "default": "0.3",
      "title": "Schema Version",
      "type": "string"
    },
    "selected_duration_seconds": {
      "exclusiveMinimum": 0,
      "title": "Selected Duration Seconds",
      "type": "number"
    },
    "selected_option_id": {
      "minLength": 1,
      "title": "Selected Option Id",
      "type": "string"
    },
    "selection_strategy": {
      "items": {
        "type": "string"
      },
      "title": "Selection Strategy",
      "type": "array"
    },
    "sound_strategy": {
      "items": {
        "type": "string"
      },
      "title": "Sound Strategy",
      "type": "array"
    },
    "source_ledger_fingerprint": {
      "minLength": 1,
      "title": "Source Ledger Fingerprint",
      "type": "string"
    },
    "source_ledger_ref": {
      "minLength": 1,
      "title": "Source Ledger Ref",
      "type": "string"
    },
    "status": {
      "pattern": "^(ready|warning|blocked)$",
      "title": "Status",
      "type": "string"
    },
    "target_platform": {
      "minLength": 1,
      "title": "Target Platform",
      "type": "string"
    },
    "theme": {
      "minLength": 1,
      "title": "Theme",
      "type": "string"
    },
    "timeline_mutated": {
      "default": false,
      "title": "Timeline Mutated",
      "type": "boolean"
    },
    "title": {
      "minLength": 1,
      "title": "Title",
      "type": "string"
    },
    "tone": {
      "items": {
        "type": "string"
      },
      "title": "Tone",
      "type": "array"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "edit_brief_id",
    "project_id",
    "title",
    "artist_name",
    "status",
    "target_platform",
    "aspect_ratio",
    "theme",
    "audience",
    "duration_source",
    "selected_option_id",
    "selected_duration_seconds",
    "duration_options",
    "evidence_summary",
    "source_ledger_ref",
    "source_ledger_fingerprint"
  ],
  "title": "EditBrief",
  "type": "object"
}
