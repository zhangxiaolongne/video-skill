{
  "$defs": {
    "ProposalId": {
      "enum": [
        "proposal_safe",
        "proposal_advanced",
        "proposal_risky"
      ],
      "title": "ProposalId",
      "type": "string"
    },
    "TimelineValidationIssue": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "minLength": 1,
          "title": "Code",
          "type": "string"
        },
        "detail": {
          "minLength": 1,
          "title": "Detail",
          "type": "string"
        },
        "segment_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Segment Id"
        },
        "severity": {
          "pattern": "^(error|warning)$",
          "title": "Severity",
          "type": "string"
        }
      },
      "required": [
        "code",
        "severity",
        "detail"
      ],
      "title": "TimelineValidationIssue",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "actual_duration": {
      "minimum": 0,
      "title": "Actual Duration",
      "type": "number"
    },
    "error_count": {
      "minimum": 0,
      "title": "Error Count",
      "type": "integer"
    },
    "input_fingerprint": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Input Fingerprint",
      "type": "string"
    },
    "issue_count": {
      "minimum": 0,
      "title": "Issue Count",
      "type": "integer"
    },
    "issues": {
      "items": {
        "$ref": "#/$defs/TimelineValidationIssue"
      },
      "title": "Issues",
      "type": "array"
    },
    "proposal_id": {
      "$ref": "#/$defs/ProposalId"
    },
    "schema_version": {
      "default": "0.3",
      "title": "Schema Version",
      "type": "string"
    },
    "segment_count": {
      "minimum": 0,
      "title": "Segment Count",
      "type": "integer"
    },
    "timeline_ref": {
      "minLength": 1,
      "title": "Timeline Ref",
      "type": "string"
    },
    "valid": {
      "title": "Valid",
      "type": "boolean"
    },
    "warning_count": {
      "minimum": 0,
      "title": "Warning Count",
      "type": "integer"
    }
  },
  "required": [
    "timeline_ref",
    "input_fingerprint",
    "proposal_id",
    "segment_count",
    "actual_duration",
    "issue_count",
    "error_count",
    "warning_count",
    "valid"
  ],
  "title": "TimelineValidationReport",
  "type": "object"
}
