{
  "$defs": {
    "FcpxmlRepairAction": {
      "additionalProperties": false,
      "properties": {
        "action_id": {
          "minLength": 1,
          "title": "Action Id",
          "type": "string"
        },
        "category": {
          "pattern": "^(asset_relink|import_blocker|mapping_review|playback_review|operator_review)$",
          "title": "Category",
          "type": "string"
        },
        "command": {
          "minLength": 1,
          "title": "Command",
          "type": "string"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "executes_automatically": {
          "default": false,
          "title": "Executes Automatically",
          "type": "boolean"
        },
        "expected_artifacts": {
          "items": {
            "type": "string"
          },
          "title": "Expected Artifacts",
          "type": "array"
        },
        "order": {
          "minimum": 1,
          "title": "Order",
          "type": "integer"
        },
        "reason": {
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        },
        "severity": {
          "pattern": "^(required|optional)$",
          "title": "Severity",
          "type": "string"
        },
        "source": {
          "pattern": "^(draft|validation|import_review|finding|playback)$",
          "title": "Source",
          "type": "string"
        }
      },
      "required": [
        "action_id",
        "order",
        "source",
        "category",
        "severity",
        "command",
        "reason"
      ],
      "title": "FcpxmlRepairAction",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "action_count": {
      "minimum": 0,
      "title": "Action Count",
      "type": "integer"
    },
    "actions": {
      "items": {
        "$ref": "#/$defs/FcpxmlRepairAction"
      },
      "title": "Actions",
      "type": "array"
    },
    "automatic_bgm_fit": {
      "default": false,
      "title": "Automatic Bgm Fit",
      "type": "boolean"
    },
    "automatic_music_selection": {
      "default": false,
      "title": "Automatic Music Selection",
      "type": "boolean"
    },
    "commands_executed": {
      "default": false,
      "title": "Commands Executed",
      "type": "boolean"
    },
    "edit_points_moved": {
      "default": false,
      "title": "Edit Points Moved",
      "type": "boolean"
    },
    "fcpxml_draft_id": {
      "minLength": 1,
      "title": "Fcpxml Draft Id",
      "type": "string"
    },
    "fcpxml_import_review_id": {
      "minLength": 1,
      "title": "Fcpxml Import Review Id",
      "type": "string"
    },
    "fcpxml_validation_id": {
      "minLength": 1,
      "title": "Fcpxml Validation Id",
      "type": "string"
    },
    "first_required_command": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "First Required Command"
    },
    "forbidden_capabilities": {
      "items": {
        "type": "string"
      },
      "title": "Forbidden Capabilities",
      "type": "array"
    },
    "image_generation_or_editing_used": {
      "default": false,
      "title": "Image Generation Or Editing Used",
      "type": "boolean"
    },
    "import_blocker_count": {
      "minimum": 0,
      "title": "Import Blocker Count",
      "type": "integer"
    },
    "media_rendered": {
      "default": false,
      "title": "Media Rendered",
      "type": "boolean"
    },
    "model_call_performed_by_cli": {
      "default": false,
      "title": "Model Call Performed By Cli",
      "type": "boolean"
    },
    "network_performed": {
      "default": false,
      "title": "Network Performed",
      "type": "boolean"
    },
    "nle_import_performed": {
      "default": false,
      "title": "Nle Import Performed",
      "type": "boolean"
    },
    "nle_plan_id": {
      "minLength": 1,
      "title": "Nle Plan Id",
      "type": "string"
    },
    "optional_action_count": {
      "minimum": 0,
      "title": "Optional Action Count",
      "type": "integer"
    },
    "playback_review_required": {
      "title": "Playback Review Required",
      "type": "boolean"
    },
    "project_id": {
      "minLength": 1,
      "title": "Project Id",
      "type": "string"
    },
    "relink_action_count": {
      "minimum": 0,
      "title": "Relink Action Count",
      "type": "integer"
    },
    "repair_plan_id": {
      "minLength": 1,
      "title": "Repair Plan Id",
      "type": "string"
    },
    "repair_success_claimed": {
      "default": false,
      "title": "Repair Success Claimed",
      "type": "boolean"
    },
    "required_action_count": {
      "minimum": 0,
      "title": "Required Action Count",
      "type": "integer"
    },
    "schema_version": {
      "default": "0.3",
      "title": "Schema Version",
      "type": "string"
    },
    "source_relink_performed": {
      "default": false,
      "title": "Source Relink Performed",
      "type": "boolean"
    },
    "status": {
      "pattern": "^(ready|warning|blocked)$",
      "title": "Status",
      "type": "string"
    },
    "timeline_mutated": {
      "default": false,
      "title": "Timeline Mutated",
      "type": "boolean"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "repair_plan_id",
    "project_id",
    "fcpxml_draft_id",
    "fcpxml_validation_id",
    "fcpxml_import_review_id",
    "nle_plan_id",
    "status",
    "action_count",
    "required_action_count",
    "optional_action_count",
    "relink_action_count",
    "import_blocker_count",
    "playback_review_required"
  ],
  "title": "FcpxmlRepairPlan",
  "type": "object"
}
