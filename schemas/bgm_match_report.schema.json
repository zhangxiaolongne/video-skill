{
  "$defs": {
    "BgmMatchCandidate": {
      "additionalProperties": false,
      "properties": {
        "beat_status": {
          "title": "Beat Status",
          "type": "string"
        },
        "bpm": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Bpm"
        },
        "compatible_option_ids": {
          "items": {
            "type": "string"
          },
          "title": "Compatible Option Ids",
          "type": "array"
        },
        "ducking_pressure": {
          "enum": [
            "low",
            "medium",
            "high"
          ],
          "title": "Ducking Pressure",
          "type": "string"
        },
        "input_mode": {
          "title": "Input Mode",
          "type": "string"
        },
        "mixed_audio": {
          "title": "Mixed Audio",
          "type": "boolean"
        },
        "mood_confidence": {
          "maximum": 1,
          "minimum": 0,
          "title": "Mood Confidence",
          "type": "number"
        },
        "mood_fit": {
          "default": "unknown",
          "enum": [
            "unknown",
            "poor",
            "partial",
            "good"
          ],
          "title": "Mood Fit",
          "type": "string"
        },
        "music_candidate_id": {
          "title": "Music Candidate Id",
          "type": "string"
        },
        "rhythm_confidence": {
          "maximum": 1,
          "minimum": 0,
          "title": "Rhythm Confidence",
          "type": "number"
        },
        "rhythm_fit": {
          "default": "unknown",
          "enum": [
            "unknown",
            "poor",
            "partial",
            "good"
          ],
          "title": "Rhythm Fit",
          "type": "string"
        },
        "source_risks": {
          "items": {
            "type": "string"
          },
          "title": "Source Risks",
          "type": "array"
        },
        "text_timing_pressure": {
          "enum": [
            "low",
            "medium",
            "high"
          ],
          "title": "Text Timing Pressure",
          "type": "string"
        },
        "transition_pressure": {
          "enum": [
            "low",
            "medium",
            "high"
          ],
          "title": "Transition Pressure",
          "type": "string"
        }
      },
      "required": [
        "music_candidate_id",
        "input_mode",
        "mixed_audio",
        "mood_confidence",
        "rhythm_confidence",
        "beat_status",
        "ducking_pressure",
        "text_timing_pressure",
        "transition_pressure"
      ],
      "title": "BgmMatchCandidate",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "automatic_music_selection": {
      "default": false,
      "title": "Automatic Music Selection",
      "type": "boolean"
    },
    "bgm_match_id": {
      "title": "Bgm Match Id",
      "type": "string"
    },
    "candidate_count": {
      "minimum": 0,
      "title": "Candidate Count",
      "type": "integer"
    },
    "candidates": {
      "items": {
        "$ref": "#/$defs/BgmMatchCandidate"
      },
      "title": "Candidates",
      "type": "array"
    },
    "fabricated_bpm_or_beats": {
      "default": false,
      "title": "Fabricated Bpm Or Beats",
      "type": "boolean"
    },
    "fabricated_mood": {
      "default": false,
      "title": "Fabricated Mood",
      "type": "boolean"
    },
    "input_state": {
      "enum": [
        "direct_audio",
        "video_audio_extract",
        "source_embedded_audio",
        "multiple_candidates",
        "no_file_yet"
      ],
      "title": "Input State",
      "type": "string"
    },
    "media_rendered": {
      "default": false,
      "title": "Media Rendered",
      "type": "boolean"
    },
    "model_call_performed_by_cli": {
      "default": false,
      "title": "Model Call Performed By Cli",
      "type": "boolean"
    },
    "network_performed": {
      "default": false,
      "title": "Network Performed",
      "type": "boolean"
    },
    "project_id": {
      "title": "Project Id",
      "type": "string"
    },
    "schema_version": {
      "default": "0.3",
      "title": "Schema Version",
      "type": "string"
    },
    "selected_candidate_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Selected Candidate Id"
    },
    "status": {
      "enum": [
        "ready",
        "degraded",
        "planning_only"
      ],
      "title": "Status",
      "type": "string"
    },
    "structure_fingerprint": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Structure Fingerprint",
      "type": "string"
    },
    "structure_ref": {
      "title": "Structure Ref",
      "type": "string"
    },
    "summary": {
      "title": "Summary",
      "type": "string"
    },
    "timeline_mutated": {
      "default": false,
      "title": "Timeline Mutated",
      "type": "boolean"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "bgm_match_id",
    "project_id",
    "structure_ref",
    "structure_fingerprint",
    "input_state",
    "candidate_count",
    "status",
    "summary"
  ],
  "title": "BgmMatchReport",
  "type": "object"
}
