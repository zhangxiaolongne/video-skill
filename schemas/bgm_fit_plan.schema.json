{
  "$defs": {
    "BgmDuckingInterval": {
      "additionalProperties": false,
      "properties": {
        "end": {
          "exclusiveMinimum": 0,
          "title": "End",
          "type": "number"
        },
        "gain_db": {
          "maximum": 0,
          "title": "Gain Db",
          "type": "number"
        },
        "reason": {
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        },
        "start": {
          "minimum": 0,
          "title": "Start",
          "type": "number"
        }
      },
      "required": [
        "start",
        "end",
        "gain_db",
        "reason"
      ],
      "title": "BgmDuckingInterval",
      "type": "object"
    },
    "BgmFitControls": {
      "additionalProperties": false,
      "properties": {
        "automatic_music_selection": {
          "default": false,
          "title": "Automatic Music Selection",
          "type": "boolean"
        },
        "beat_alignment_requested": {
          "title": "Beat Alignment Requested",
          "type": "boolean"
        },
        "control_policy": {
          "pattern": "^(default_v1|explicit_cli_v1)$",
          "title": "Control Policy",
          "type": "string"
        },
        "ducking_enabled": {
          "title": "Ducking Enabled",
          "type": "boolean"
        },
        "ducking_gain_db": {
          "maximum": 0,
          "title": "Ducking Gain Db",
          "type": "number"
        },
        "edit_points_moved": {
          "default": false,
          "title": "Edit Points Moved",
          "type": "boolean"
        },
        "fade_in_seconds": {
          "minimum": 0,
          "title": "Fade In Seconds",
          "type": "number"
        },
        "fade_out_seconds": {
          "minimum": 0,
          "title": "Fade Out Seconds",
          "type": "number"
        },
        "requested_fit_mode": {
          "pattern": "^(auto|single_pass|trim|loop)$",
          "title": "Requested Fit Mode",
          "type": "string"
        },
        "target_gain_db": {
          "title": "Target Gain Db",
          "type": "number"
        }
      },
      "required": [
        "control_policy",
        "requested_fit_mode",
        "fade_in_seconds",
        "fade_out_seconds",
        "target_gain_db",
        "ducking_enabled",
        "ducking_gain_db",
        "beat_alignment_requested"
      ],
      "title": "BgmFitControls",
      "type": "object"
    },
    "BgmFitSegment": {
      "additionalProperties": false,
      "properties": {
        "loop_index": {
          "minimum": 0,
          "title": "Loop Index",
          "type": "integer"
        },
        "source_in": {
          "minimum": 0,
          "title": "Source In",
          "type": "number"
        },
        "source_out": {
          "exclusiveMinimum": 0,
          "title": "Source Out",
          "type": "number"
        },
        "timeline_end": {
          "exclusiveMinimum": 0,
          "title": "Timeline End",
          "type": "number"
        },
        "timeline_start": {
          "minimum": 0,
          "title": "Timeline Start",
          "type": "number"
        }
      },
      "required": [
        "timeline_start",
        "timeline_end",
        "source_in",
        "source_out",
        "loop_index"
      ],
      "title": "BgmFitSegment",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "analysis_fingerprint": {
      "anyOf": [
        {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Analysis Fingerprint"
    },
    "analysis_ref": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Analysis Ref"
    },
    "beat_alignment_status": {
      "pattern": "^(unavailable|not_requested|completed)$",
      "title": "Beat Alignment Status",
      "type": "string"
    },
    "beat_evidence_status": {
      "default": "unavailable",
      "pattern": "^(unavailable|bound)$",
      "title": "Beat Evidence Status",
      "type": "string"
    },
    "beat_grid_fingerprint": {
      "anyOf": [
        {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Beat Grid Fingerprint"
    },
    "beat_grid_ref": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Beat Grid Ref"
    },
    "candidate_content_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Candidate Content Hash",
      "type": "string"
    },
    "controls": {
      "$ref": "#/$defs/BgmFitControls"
    },
    "ducking_intervals": {
      "items": {
        "$ref": "#/$defs/BgmDuckingInterval"
      },
      "title": "Ducking Intervals",
      "type": "array"
    },
    "energy_alignment_status": {
      "default": "unavailable",
      "pattern": "^(unavailable|analysis_used)$",
      "title": "Energy Alignment Status",
      "type": "string"
    },
    "fade_in_seconds": {
      "minimum": 0,
      "title": "Fade In Seconds",
      "type": "number"
    },
    "fade_out_seconds": {
      "minimum": 0,
      "title": "Fade Out Seconds",
      "type": "number"
    },
    "fit_id": {
      "minLength": 1,
      "title": "Fit Id",
      "type": "string"
    },
    "fit_mode": {
      "pattern": "^(single_pass|trim|loop)$",
      "title": "Fit Mode",
      "type": "string"
    },
    "music_candidate_id": {
      "minLength": 1,
      "title": "Music Candidate Id",
      "type": "string"
    },
    "project_id": {
      "minLength": 1,
      "title": "Project Id",
      "type": "string"
    },
    "schema_version": {
      "default": "0.3",
      "title": "Schema Version",
      "type": "string"
    },
    "segments": {
      "items": {
        "$ref": "#/$defs/BgmFitSegment"
      },
      "minItems": 1,
      "title": "Segments",
      "type": "array"
    },
    "target_duration": {
      "exclusiveMinimum": 0,
      "title": "Target Duration",
      "type": "number"
    },
    "target_gain_db": {
      "title": "Target Gain Db",
      "type": "number"
    },
    "timeline_fingerprint": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Timeline Fingerprint",
      "type": "string"
    },
    "timeline_id": {
      "minLength": 1,
      "title": "Timeline Id",
      "type": "string"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "fit_id",
    "project_id",
    "timeline_id",
    "timeline_fingerprint",
    "music_candidate_id",
    "candidate_content_hash",
    "target_duration",
    "fit_mode",
    "segments",
    "fade_in_seconds",
    "fade_out_seconds",
    "target_gain_db",
    "controls",
    "beat_alignment_status"
  ],
  "title": "BgmFitPlan",
  "type": "object"
}
