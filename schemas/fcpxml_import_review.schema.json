    "project_id",
    "fcpxml_draft_id",
    "nle_plan_id",
    "candidate_fingerprint",
    "quarantine_ref",
    "status",
    "binding_status",
    "import_attempted",
    "import_success_claimed",
    "relink_success_claimed",
    "timeline_opened",
    "playback_checked",
    "issue_count",
    "accepted_issue_count",
    "warning_count",
    "error_count"
