{
  "$defs": {
    "FcpxmlImportReviewIssue": {
      "additionalProperties": false,
      "properties": {
        "category": {
          "minLength": 1,
          "title": "Category",
          "type": "string"
        },
        "detail": {
          "minLength": 1,
          "title": "Detail",
          "type": "string"
        },
        "issue_id": {
          "minLength": 1,
          "title": "Issue Id",
          "type": "string"
        },
        "severity": {
          "pattern": "^(info|warning|error)$",
          "title": "Severity",
          "type": "string"
        }
      },
      "required": [
        "issue_id",
        "severity",
        "category",
        "detail"
      ],
      "title": "FcpxmlImportReviewIssue",
      "type": "object"
    }
  },
  "additionalProperties": false,
