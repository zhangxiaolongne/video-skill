    },
    "import_attempted": {
      "title": "Import Attempted",
      "type": "boolean"
    },
    "import_success_accepted_as_project_success": {
      "default": false,
      "title": "Import Success Accepted As Project Success",
      "type": "boolean"
    },
    "import_success_claimed": {
      "title": "Import Success Claimed",
      "type": "boolean"
    },
    "issue_count": {
      "minimum": 0,
      "title": "Issue Count",
      "type": "integer"
    },
    "media_rendered": {
      "default": false,
      "title": "Media Rendered",
      "type": "boolean"
    },
    "model_call_performed_by_cli": {
      "default": false,
      "title": "Model Call Performed By Cli",
      "type": "boolean"
    },
    "network_performed": {
      "default": false,
      "title": "Network Performed",
      "type": "boolean"
    },
    "nle_plan_id": {
      "minLength": 1,
      "title": "Nle Plan Id",
      "type": "string"
    },
    "playback_checked": {
      "title": "Playback Checked",
      "type": "boolean"
    },
    "project_id": {
      "minLength": 1,
      "title": "Project Id",
      "type": "string"
    },
    "quarantine_ref": {
      "minLength": 1,
      "title": "Quarantine Ref",
      "type": "string"
    },
    "rejected_reasons": {
      "items": {
        "type": "string"
      },
      "title": "Rejected Reasons",
      "type": "array"
    },
    "relink_success_claimed": {
      "title": "Relink Success Claimed",
      "type": "boolean"
    },
    "review_id": {
      "minLength": 1,
      "title": "Review Id",
      "type": "string"
