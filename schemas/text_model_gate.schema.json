{
  "$defs": {
    "TextModelGateStatus": {
      "enum": [
        "blocked",
        "ready"
      ],
      "title": "TextModelGateStatus",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "gate_id": {
      "minLength": 1,
      "title": "Gate Id",
      "type": "string"
    },
    "include_absolute_paths_in_remote_requests": {
      "title": "Include Absolute Paths In Remote Requests",
      "type": "boolean"
    },
    "project_id": {
      "minLength": 1,
      "title": "Project Id",
      "type": "string"
    },
    "proposal_context_fingerprint": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Proposal Context Fingerprint",
      "type": "string"
    },
    "proposal_context_ref": {
      "minLength": 1,
      "title": "Proposal Context Ref",
      "type": "string"
    },
    "reasons": {
      "items": {
        "type": "string"
      },
      "title": "Reasons",
      "type": "array"
    },
    "remote_text_model_allowed": {
      "title": "Remote Text Model Allowed",
      "type": "boolean"
    },
    "required_next_steps": {
      "items": {
        "type": "string"
      },
      "title": "Required Next Steps",
      "type": "array"
    },
    "schema_version": {
      "default": "0.3",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/TextModelGateStatus"
    },
    "text_model_capability": {
      "title": "Text Model Capability",
      "type": "boolean"
    }
  },
  "required": [
    "gate_id",
    "project_id",
    "proposal_context_ref",
    "proposal_context_fingerprint",
    "status",
    "remote_text_model_allowed",
    "text_model_capability",
    "include_absolute_paths_in_remote_requests"
  ],
  "title": "TextModelGate",
  "type": "object"
}
