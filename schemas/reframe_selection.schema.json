{
  "$defs": {
    "SegmentReframeChoice": {
      "additionalProperties": false,
      "properties": {
        "candidate_id": {
          "anyOf": [
            {
              "pattern": "^reframe_[a-z0-9_]+$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Candidate Id"
        },
        "mode": {
          "enum": [
            "candidate",
            "preserve"
          ],
          "title": "Mode",
          "type": "string"
        },
        "reason": {
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        },
        "segment_id": {
          "minLength": 1,
          "title": "Segment Id",
          "type": "string"
        }
      },
      "required": [
        "segment_id",
        "mode",
        "reason"
      ],
      "title": "SegmentReframeChoice",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "approval_note": {
      "minLength": 1,
      "title": "Approval Note",
      "type": "string"
    },
    "approved_by": {
      "pattern": "^(user|host_agent|human_editor)$",
      "title": "Approved By",
      "type": "string"
    },
    "choices": {
      "items": {
        "$ref": "#/$defs/SegmentReframeChoice"
      },
      "minItems": 1,
      "title": "Choices",
      "type": "array"
    },
    "composition_review_fingerprint": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Composition Review Fingerprint",
      "type": "string"
    },
    "composition_review_id": {
      "minLength": 1,
      "title": "Composition Review Id",
      "type": "string"
    },
    "final_export_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Final Export Hash",
      "type": "string"
    },
    "project_id": {
      "minLength": 1,
      "title": "Project Id",
      "type": "string"
    },
    "schema_version": {
      "default": "0.3",
      "title": "Schema Version",
      "type": "string"
    },
    "selection_id": {
      "minLength": 1,
      "title": "Selection Id",
      "type": "string"
    },
    "timeline_fingerprint": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Timeline Fingerprint",
      "type": "string"
    },
    "timeline_id": {
      "minLength": 1,
      "title": "Timeline Id",
      "type": "string"
    }
  },
  "required": [
    "selection_id",
    "project_id",
    "timeline_id",
    "timeline_fingerprint",
    "final_export_hash",
    "composition_review_id",
    "composition_review_fingerprint",
    "choices",
    "approved_by",
    "approval_note"
  ],
  "title": "ReframeSelection",
  "type": "object"
}
