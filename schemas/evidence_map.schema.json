{
  "$defs": {
    "EvidenceChannel": {
      "additionalProperties": false,
      "properties": {
        "confidence": {
          "maximum": 1,
          "minimum": 0,
          "title": "Confidence",
          "type": "number"
        },
        "facts": {
          "additionalProperties": true,
          "title": "Facts",
          "type": "object"
        },
        "limitations": {
          "items": {
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        },
        "missing_reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Missing Reason"
        },
        "refs": {
          "items": {
            "type": "string"
          },
          "title": "Refs",
          "type": "array"
        },
        "status": {
          "enum": [
            "available",
            "partial",
            "unavailable",
            "not_applicable"
          ],
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "status",
        "confidence"
      ],
      "title": "EvidenceChannel",
      "type": "object"
    },
    "EvidenceMapUnit": {
      "additionalProperties": false,
      "properties": {
        "audio": {
          "$ref": "#/$defs/EvidenceChannel"
        },
        "clip_fingerprint": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Clip Fingerprint",
          "type": "string"
        },
        "clip_id": {
          "minLength": 1,
          "title": "Clip Id",
          "type": "string"
        },
        "conflict_risks": {
          "items": {
            "type": "string"
          },
          "title": "Conflict Risks",
          "type": "array"
        },
        "degradation_reasons": {
          "items": {
            "type": "string"
          },
          "title": "Degradation Reasons",
          "type": "array"
        },
        "downstream_usable_features": {
          "items": {
            "type": "string"
          },
          "title": "Downstream Usable Features",
          "type": "array"
        },
        "end_seconds": {
          "exclusiveMinimum": 0,
          "title": "End Seconds",
          "type": "number"
        },
        "media_kind": {
          "enum": [
            "video",
            "audio",
            "image"
          ],
          "title": "Media Kind",
          "type": "string"
        },
        "scene_confidence": {
          "maximum": 1,
          "minimum": 0,
          "title": "Scene Confidence",
          "type": "number"
        },
        "scene_method": {
          "minLength": 1,
          "title": "Scene Method",
          "type": "string"
        },
        "semantic_unknowns": {
          "items": {
            "type": "string"
          },
          "title": "Semantic Unknowns",
          "type": "array"
        },
        "source_content_hash": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Source Content Hash",
          "type": "string"
        },
        "source_id": {
          "minLength": 1,
          "title": "Source Id",
          "type": "string"
        },
        "start_seconds": {
          "minimum": 0,
          "title": "Start Seconds",
          "type": "number"
        },
        "transcript": {
          "$ref": "#/$defs/EvidenceChannel"
        },
        "unit_id": {
          "minLength": 1,
          "title": "Unit Id",
          "type": "string"
        },
        "user_goal": {
          "$ref": "#/$defs/EvidenceChannel"
        },
        "vision": {
          "$ref": "#/$defs/EvidenceChannel"
        }
      },
      "required": [
        "unit_id",
        "source_id",
        "source_content_hash",
        "clip_id",
        "media_kind",
        "clip_fingerprint",
        "start_seconds",
        "end_seconds",
        "scene_method",
        "scene_confidence",
        "transcript",
        "vision",
        "audio",
        "user_goal"
      ],
      "title": "EvidenceMapUnit",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "audio_feature_coverage_ratio": {
      "maximum": 1,
      "minimum": 0,
      "title": "Audio Feature Coverage Ratio",
      "type": "number"
    },
    "evidence_map_id": {
      "minLength": 1,
      "title": "Evidence Map Id",
      "type": "string"
    },
    "fabricated_semantics": {
      "default": false,
      "title": "Fabricated Semantics",
      "type": "boolean"
    },
    "global_unknowns": {
      "items": {
        "type": "string"
      },
      "title": "Global Unknowns",
      "type": "array"
    },
    "input_fingerprints": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Input Fingerprints",
      "type": "object"
    },
    "keyframe_coverage_ratio": {
      "maximum": 1,
      "minimum": 0,
      "title": "Keyframe Coverage Ratio",
      "type": "number"
    },
    "model_call_performed_by_cli": {
      "default": false,
      "title": "Model Call Performed By Cli",
      "type": "boolean"
    },
    "network_performed": {
      "default": false,
      "title": "Network Performed",
      "type": "boolean"
    },
    "overall_status": {
      "enum": [
        "ready",
        "degraded",
        "blocked"
      ],
      "title": "Overall Status",
      "type": "string"
    },
    "paid_api_used": {
      "default": false,
      "title": "Paid Api Used",
      "type": "boolean"
    },
    "project_id": {
      "minLength": 1,
      "title": "Project Id",
      "type": "string"
    },
    "scene_detection_ratio": {
      "maximum": 1,
      "minimum": 0,
      "title": "Scene Detection Ratio",
      "type": "number"
    },
    "schema_version": {
      "default": "0.3",
      "title": "Schema Version",
      "type": "string"
    },
    "transcript_coverage_ratio": {
      "maximum": 1,
      "minimum": 0,
      "title": "Transcript Coverage Ratio",
      "type": "number"
    },
    "unit_count": {
      "minimum": 1,
      "title": "Unit Count",
      "type": "integer"
    },
    "units": {
      "items": {
        "$ref": "#/$defs/EvidenceMapUnit"
      },
      "minItems": 1,
      "title": "Units",
      "type": "array"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "evidence_map_id",
    "project_id",
    "input_fingerprints",
    "unit_count",
    "transcript_coverage_ratio",
    "keyframe_coverage_ratio",
    "audio_feature_coverage_ratio",
    "scene_detection_ratio",
    "overall_status",
    "units"
  ],
  "title": "EvidenceMap",
  "type": "object"
}
