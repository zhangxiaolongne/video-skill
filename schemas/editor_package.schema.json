{
  "$defs": {
    "EditorPackageArtifactBinding": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "minLength": 1,
          "title": "Artifact Id",
          "type": "string"
        },
        "ref": {
          "minLength": 1,
          "title": "Ref",
          "type": "string"
        },
        "status": {
          "pattern": "^(present|missing|optional_missing)$",
          "title": "Status",
          "type": "string"
        },
        "summary": {
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "ref",
        "status",
        "summary"
      ],
      "title": "EditorPackageArtifactBinding",
      "type": "object"
    },
    "EditorPackageAudioItem": {
      "additionalProperties": false,
      "properties": {
        "category": {
          "pattern": "^(bgm_segment|ducking|fade|gain|beat_alignment)$",
          "title": "Category",
          "type": "string"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "instruction": {
          "minLength": 1,
          "title": "Instruction",
          "type": "string"
        },
        "item_id": {
          "minLength": 1,
          "title": "Item Id",
          "type": "string"
        },
        "order": {
          "minimum": 1,
          "title": "Order",
          "type": "integer"
        },
        "timeline_end": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Timeline End"
        },
        "timeline_start": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Timeline Start"
        }
      },
      "required": [
        "item_id",
        "order",
        "category",
        "instruction"
      ],
      "title": "EditorPackageAudioItem",
      "type": "object"
    },
    "EditorPackageManualAction": {
      "additionalProperties": false,
      "properties": {
        "action_id": {
          "minLength": 1,
          "title": "Action Id",
          "type": "string"
        },
        "category": {
          "minLength": 1,
          "title": "Category",
          "type": "string"
        },
        "edits_applied": {
          "default": false,
          "title": "Edits Applied",
          "type": "boolean"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "instruction": {
          "minLength": 1,
          "title": "Instruction",
          "type": "string"
        },
        "manual_only": {
          "default": true,
          "title": "Manual Only",
          "type": "boolean"
        },
        "order": {
          "minimum": 1,
          "title": "Order",
          "type": "integer"
        },
        "priority": {
          "pattern": "^(low|medium|high)$",
          "title": "Priority",
          "type": "string"
        },
        "rationale": {
          "minLength": 1,
          "title": "Rationale",
          "type": "string"
        },
        "timeline_end": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Timeline End"
        },
        "timeline_start": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Timeline Start"
        }
      },
      "required": [
        "action_id",
        "order",
        "category",
        "priority",
        "instruction",
        "rationale"
      ],
      "title": "EditorPackageManualAction",
      "type": "object"
    },
    "EditorPackageTimelineItem": {
      "additionalProperties": false,
      "properties": {
        "audio_transition": {
          "minLength": 1,
          "title": "Audio Transition",
          "type": "string"
        },
        "clip_id": {
          "minLength": 1,
          "title": "Clip Id",
          "type": "string"
        },
        "creative_intent": {
          "minLength": 1,
          "title": "Creative Intent",
          "type": "string"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "item_id": {
          "minLength": 1,
          "title": "Item Id",
          "type": "string"
        },
        "media_role": {
          "pattern": "^(video|audio|both)$",
          "title": "Media Role",
          "type": "string"
        },
        "order": {
          "minimum": 1,
          "title": "Order",
          "type": "integer"
        },
        "source_id": {
          "minLength": 1,
          "title": "Source Id",
          "type": "string"
        },
        "source_in": {
          "minimum": 0,
          "title": "Source In",
          "type": "number"
        },
        "source_out": {
          "exclusiveMinimum": 0,
          "title": "Source Out",
          "type": "number"
        },
        "timeline_end": {
          "exclusiveMinimum": 0,
          "title": "Timeline End",
          "type": "number"
        },
        "timeline_start": {
          "minimum": 0,
          "title": "Timeline Start",
          "type": "number"
        },
        "track_id": {
          "minLength": 1,
          "title": "Track Id",
          "type": "string"
        },
        "video_transition": {
          "minLength": 1,
          "title": "Video Transition",
          "type": "string"
        }
      },
      "required": [
        "item_id",
        "order",
        "track_id",
        "timeline_start",
        "timeline_end",
        "source_id",
        "clip_id",
        "source_in",
        "source_out",
        "media_role",
        "video_transition",
        "audio_transition",
        "creative_intent"
      ],
      "title": "EditorPackageTimelineItem",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "actual_duration": {
      "exclusiveMinimum": 0,
      "title": "Actual Duration",
      "type": "number"
    },
    "artifact_bindings": {
      "items": {
        "$ref": "#/$defs/EditorPackageArtifactBinding"
      },
      "title": "Artifact Bindings",
      "type": "array"
    },
    "audio_item_count": {
      "minimum": 0,
      "title": "Audio Item Count",
      "type": "integer"
    },
    "audio_items": {
      "items": {
        "$ref": "#/$defs/EditorPackageAudioItem"
      },
      "title": "Audio Items",
      "type": "array"
    },
    "automatic_bgm_fit": {
      "default": false,
      "title": "Automatic Bgm Fit",
      "type": "boolean"
    },
    "automatic_music_selection": {
      "default": false,
      "title": "Automatic Music Selection",
      "type": "boolean"
    },
    "commands_executed": {
      "default": false,
      "title": "Commands Executed",
      "type": "boolean"
    },
    "cue_sheet_row_count": {
      "minimum": 0,
      "title": "Cue Sheet Row Count",
      "type": "integer"
    },
    "edit_points_moved": {
      "default": false,
      "title": "Edit Points Moved",
      "type": "boolean"
    },
    "editor_package_id": {
      "minLength": 1,
      "title": "Editor Package Id",
      "type": "string"
    },
    "forbidden_capabilities": {
      "items": {
        "type": "string"
      },
      "title": "Forbidden Capabilities",
      "type": "array"
    },
    "image_generation_or_editing_used": {
      "default": false,
      "title": "Image Generation Or Editing Used",
      "type": "boolean"
    },
    "manual_action_count": {
      "minimum": 0,
      "title": "Manual Action Count",
      "type": "integer"
    },
    "manual_actions": {
      "items": {
        "$ref": "#/$defs/EditorPackageManualAction"
      },
      "title": "Manual Actions",
      "type": "array"
    },
    "media_rendered": {
      "default": false,
      "title": "Media Rendered",
      "type": "boolean"
    },
    "model_call_performed_by_cli": {
      "default": false,
      "title": "Model Call Performed By Cli",
      "type": "boolean"
    },
    "network_performed": {
      "default": false,
      "title": "Network Performed",
      "type": "boolean"
    },
    "project_id": {
      "minLength": 1,
      "title": "Project Id",
      "type": "string"
    },
    "schema_version": {
      "default": "0.3",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "pattern": "^(ready|warning|blocked)$",
      "title": "Status",
      "type": "string"
    },
    "target_duration": {
      "exclusiveMinimum": 0,
      "title": "Target Duration",
      "type": "number"
    },
    "timeline_fingerprint": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Timeline Fingerprint",
      "type": "string"
    },
    "timeline_id": {
      "minLength": 1,
      "title": "Timeline Id",
      "type": "string"
    },
    "timeline_item_count": {
      "minimum": 0,
      "title": "Timeline Item Count",
      "type": "integer"
    },
    "timeline_items": {
      "items": {
        "$ref": "#/$defs/EditorPackageTimelineItem"
      },
      "title": "Timeline Items",
      "type": "array"
    },
    "timeline_mutated": {
      "default": false,
      "title": "Timeline Mutated",
      "type": "boolean"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "editor_package_id",
    "project_id",
    "timeline_id",
    "timeline_fingerprint",
    "status",
    "target_duration",
    "actual_duration",
    "timeline_item_count",
    "audio_item_count",
    "manual_action_count",
    "cue_sheet_row_count"
  ],
  "title": "EditorPackage",
  "type": "object"
}
