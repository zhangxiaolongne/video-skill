          "title": "Duration Source",
          "type": "string"
        },
        "estimated_duration_seconds": {
          "exclusiveMinimum": 0,
          "title": "Estimated Duration Seconds",
          "type": "number"
        },
        "option_id": {
          "enum": [
            "short",
            "standard",
            "extended"
