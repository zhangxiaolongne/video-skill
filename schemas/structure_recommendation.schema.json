    "edit_brief_id": {
      "title": "Edit Brief Id",
      "type": "string"
    },
    "edit_brief_ref": {
      "title": "Edit Brief Ref",
      "type": "string"
    },
    "edit_points_applied": {
      "default": false,
      "title": "Edit Points Applied",
      "type": "boolean"
    },
    "explicit_standard_duration_seconds": {
      "exclusiveMinimum": 0,
      "title": "Explicit Standard Duration Seconds",
      "type": "number"
    },
