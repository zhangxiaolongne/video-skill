      "default": "0.3",
      "title": "Schema Version",
      "type": "string"
    },
    "score_set_fingerprint": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Score Set Fingerprint",
      "type": "string"
    },
    "score_set_id": {
      "title": "Score Set Id",
      "type": "string"
    },
    "score_set_ref": {
      "title": "Score Set Ref",
      "type": "string"
    },
    "status": {
      "enum": [
        "ready",
        "degraded"
      ],
      "title": "Status",
      "type": "string"
    },
    "target_platform": {
      "title": "Target Platform",
      "type": "string"
    },
    "timeline_mutated": {
      "default": false,
      "title": "Timeline Mutated",
      "type": "boolean"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
