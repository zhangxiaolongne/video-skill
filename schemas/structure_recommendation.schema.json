{
  "$defs": {
    "RecommendedRange": {
      "additionalProperties": false,
      "properties": {
        "candidate_id": {
          "title": "Candidate Id",
          "type": "string"
        },
        "planned_duration": {
          "exclusiveMinimum": 0,
          "title": "Planned Duration",
          "type": "number"
        },
        "ranking_confidence": {
          "maximum": 1,
          "minimum": 0,
          "title": "Ranking Confidence",
          "type": "number"
        },
        "rationale": {
          "minLength": 1,
          "title": "Rationale",
          "type": "string"
        },
        "role": {
          "enum": [
            "hook",
            "build",
            "payoff"
          ],
          "title": "Role",
          "type": "string"
        },
        "score": {
          "maximum": 1,
          "minimum": 0,
          "title": "Score",
          "type": "number"
        },
        "source_id": {
          "title": "Source Id",
          "type": "string"
        },
        "source_in": {
          "minimum": 0,
          "title": "Source In",
          "type": "number"
        },
        "source_out": {
          "exclusiveMinimum": 0,
          "title": "Source Out",
          "type": "number"
        }
      },
      "required": [
        "candidate_id",
        "role",
        "source_id",
        "source_in",
        "source_out",
        "planned_duration",
        "score",
        "ranking_confidence",
        "rationale"
      ],
      "title": "RecommendedRange",
      "type": "object"
    },
