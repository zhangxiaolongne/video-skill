      "required": [
        "option_id",
        "target_duration_seconds",
        "estimated_duration_seconds",
        "duration_source",
        "ranges",
        "role_allocation_seconds",
        "retained_qualities",
        "sacrifices",
        "coupled_risks",
        "recommendation_confidence"
      ],
      "title": "StructureOption",
      "type": "object"
