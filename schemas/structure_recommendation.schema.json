        "sacrifices": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Sacrifices",
          "type": "array"
        },
        "target_duration_seconds": {
          "exclusiveMinimum": 0,
          "title": "Target Duration Seconds",
          "type": "number"
        }
