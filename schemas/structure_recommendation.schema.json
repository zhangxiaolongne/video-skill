  "required": [
    "recommendation_id",
    "project_id",
    "score_set_id",
    "score_set_ref",
    "score_set_fingerprint",
    "edit_brief_id",
    "edit_brief_ref",
    "edit_brief_fingerprint",
    "target_platform",
    "explicit_standard_duration_seconds",
    "options",
    "recommended_option_id",
    "status"
