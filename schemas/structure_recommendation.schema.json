      "minItems": 3,
      "title": "Options",
      "type": "array"
    },
    "project_id": {
      "title": "Project Id",
      "type": "string"
    },
    "recommendation_id": {
      "title": "Recommendation Id",
      "type": "string"
    },
    "recommended_option_id": {
      "enum": [
        "short",
        "standard",
        "extended"
