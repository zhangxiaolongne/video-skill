{
  "$defs": {
    "ProposalValidationIssue": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "minLength": 1,
          "title": "Code",
          "type": "string"
        },
        "detail": {
          "minLength": 1,
          "title": "Detail",
          "type": "string"
        },
        "proposal_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Proposal Id"
        },
        "ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ref"
        },
        "severity": {
          "pattern": "^(info|warning|error)$",
          "title": "Severity",
          "type": "string"
        }
      },
      "required": [
        "code",
        "severity",
        "detail"
      ],
      "title": "ProposalValidationIssue",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "error_count": {
      "minimum": 0,
      "title": "Error Count",
      "type": "integer"
    },
    "input_fingerprint": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Input Fingerprint",
      "type": "string"
    },
    "issue_count": {
      "minimum": 0,
      "title": "Issue Count",
      "type": "integer"
    },
    "issues": {
      "items": {
        "$ref": "#/$defs/ProposalValidationIssue"
      },
      "title": "Issues",
      "type": "array"
    },
    "project_id": {
      "minLength": 1,
      "title": "Project Id",
      "type": "string"
    },
    "proposal_context_ref": {
      "minLength": 1,
      "title": "Proposal Context Ref",
      "type": "string"
    },
    "proposal_count": {
      "minimum": 0,
      "title": "Proposal Count",
      "type": "integer"
    },
    "proposal_set_id": {
      "minLength": 1,
      "title": "Proposal Set Id",
      "type": "string"
    },
    "proposals_ref": {
      "minLength": 1,
      "title": "Proposals Ref",
      "type": "string"
    },
    "report_id": {
      "minLength": 1,
      "title": "Report Id",
      "type": "string"
    },
    "schema_version": {
      "default": "0.3",
      "title": "Schema Version",
      "type": "string"
    },
    "warning_count": {
      "minimum": 0,
      "title": "Warning Count",
      "type": "integer"
    }
  },
  "required": [
    "report_id",
    "project_id",
    "proposal_set_id",
    "proposal_context_ref",
    "proposals_ref",
    "input_fingerprint",
    "proposal_count",
    "issue_count",
    "error_count",
    "warning_count"
  ],
  "title": "ProposalValidationReport",
  "type": "object"
}
