      "default": false,
      "title": "Automatic Bgm Fit By Cli",
      "type": "boolean"
    },
    "automatic_music_selection_by_cli": {
      "default": false,
      "title": "Automatic Music Selection By Cli",
      "type": "boolean"
    },
    "commands_executed_by_cli": {
      "default": false,
      "title": "Commands Executed By Cli",
      "type": "boolean"
    },
    "dry_run_id": {
      "minLength": 1,
      "title": "Dry Run Id",
      "type": "string"
    },
    "edit_points_moved_by_cli": {
      "default": false,
      "title": "Edit Points Moved By Cli",
      "type": "boolean"
    },
    "executed_by": {
      "minLength": 1,
      "title": "Executed By",
      "type": "string"
