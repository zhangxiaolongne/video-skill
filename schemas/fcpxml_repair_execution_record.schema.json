{
  "$defs": {
    "FcpxmlRepairExecutionActionRecord": {
      "additionalProperties": false,
      "properties": {
        "action_id": {
          "minLength": 1,
          "title": "Action Id",
          "type": "string"
        },
        "command": {
          "minLength": 1,
          "title": "Command",
          "type": "string"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "exit_code": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Exit Code"
        },
        "notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Notes"
        },
        "output_refs": {
          "items": {
            "type": "string"
          },
          "title": "Output Refs",
          "type": "array"
        },
        "status": {
          "pattern": "^(succeeded|failed|skipped)$",
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "action_id",
        "command",
        "status"
      ],
      "title": "FcpxmlRepairExecutionActionRecord",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "acceptance_success_promoted_by_cli": {
      "default": false,
      "title": "Acceptance Success Promoted By Cli",
      "type": "boolean"
    },
    "actions": {
