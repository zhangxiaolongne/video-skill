{
  "$defs": {
    "WorkflowExecutionStepRecord": {
      "additionalProperties": false,
      "properties": {
        "command": {
          "minLength": 1,
          "title": "Command",
          "type": "string"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "exit_code": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Exit Code"
        },
        "notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Notes"
        },
        "output_refs": {
          "items": {
            "type": "string"
          },
          "title": "Output Refs",
          "type": "array"
        },
        "status": {
          "pattern": "^(succeeded|failed|skipped)$",
          "title": "Status",
          "type": "string"
        },
        "step_id": {
          "minLength": 1,
          "title": "Step Id",
          "type": "string"
        }
      },
      "required": [
        "step_id",
        "command",
        "status"
      ],
      "title": "WorkflowExecutionStepRecord",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "automatic_music_selection_by_cli": {
      "default": false,
      "title": "Automatic Music Selection By Cli",
      "type": "boolean"
    },
    "commands_executed_by_cli": {
      "default": false,
      "title": "Commands Executed By Cli",
      "type": "boolean"
    },
    "edit_points_moved_by_cli": {
      "default": false,
      "title": "Edit Points Moved By Cli",
      "type": "boolean"
    },
    "executed_by": {
      "minLength": 1,
      "title": "Executed By",
      "type": "string"
    },
    "execution_record_id": {
      "minLength": 1,
      "title": "Execution Record Id",
      "type": "string"
    },
    "media_rendered_by_cli": {
      "default": false,
      "title": "Media Rendered By Cli",
      "type": "boolean"
    },
    "model_call_performed_by_cli": {
      "default": false,
      "title": "Model Call Performed By Cli",
      "type": "boolean"
    },
    "network_performed_by_cli": {
      "default": false,
      "title": "Network Performed By Cli",
      "type": "boolean"
    },
    "project_id": {
      "minLength": 1,
      "title": "Project Id",
      "type": "string"
    },
    "schema_version": {
      "default": "0.3",
      "title": "Schema Version",
      "type": "string"
    },
    "steps": {
      "items": {
        "$ref": "#/$defs/WorkflowExecutionStepRecord"
      },
      "title": "Steps",
      "type": "array"
    },
    "target": {
      "pattern": "^(core|preview|delivery)$",
      "title": "Target",
      "type": "string"
    },
    "workflow_plan_id": {
      "minLength": 1,
      "title": "Workflow Plan Id",
      "type": "string"
    }
  },
  "required": [
    "execution_record_id",
    "project_id",
    "workflow_plan_id",
    "target",
    "executed_by"
  ],
  "title": "WorkflowExecutionRecord",
  "type": "object"
}
