{
  "$defs": {
    "RevisionPromotionInvalidation": {
      "additionalProperties": false,
      "properties": {
        "output_refs": {
          "items": {
            "type": "string"
          },
          "title": "Output Refs",
          "type": "array"
        },
        "previous_status": {
          "minLength": 1,
          "title": "Previous Status",
          "type": "string"
        },
        "reason": {
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        },
        "step": {
          "minLength": 1,
          "title": "Step",
          "type": "string"
        }
      },
      "required": [
        "step",
        "previous_status",
        "reason"
      ],
      "title": "RevisionPromotionInvalidation",
      "type": "object"
    },
    "RevisionPromotionSegmentBinding": {
      "additionalProperties": false,
      "properties": {
        "action_ids": {
          "items": {
            "type": "string"
          },
          "title": "Action Ids",
          "type": "array"
        },
        "baseline_timeline_end": {
          "exclusiveMinimum": 0,
          "title": "Baseline Timeline End",
          "type": "number"
        },
        "baseline_timeline_start": {
          "minimum": 0,
          "title": "Baseline Timeline Start",
          "type": "number"
        },
        "duration_delta_seconds": {
          "default": 0.0,
          "title": "Duration Delta Seconds",
          "type": "number"
        },
        "promoted_segment_id": {
          "minLength": 1,
          "title": "Promoted Segment Id",
          "type": "string"
        },
        "promoted_timeline_end": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Promoted Timeline End"
        },
        "promoted_timeline_start": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Promoted Timeline Start"
        },
        "source_segment_id": {
          "minLength": 1,
          "title": "Source Segment Id",
          "type": "string"
        },
        "status": {
          "pattern": "^(kept|trimmed|removed|moved|unchanged)$",
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "source_segment_id",
        "promoted_segment_id",
        "status",
        "baseline_timeline_start",
        "baseline_timeline_end"
      ],
      "title": "RevisionPromotionSegmentBinding",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "automatic_bgm_fit": {
      "default": false,
      "title": "Automatic Bgm Fit",
      "type": "boolean"
    },
    "automatic_music_selection": {
      "default": false,
      "title": "Automatic Music Selection",
      "type": "boolean"
    },
    "baseline_segment_count": {
      "minimum": 0,
      "title": "Baseline Segment Count",
      "type": "integer"
    },
    "baseline_timeline_fingerprint": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Baseline Timeline Fingerprint",
      "type": "string"
    },
    "baseline_timeline_id": {
      "minLength": 1,
      "title": "Baseline Timeline Id",
      "type": "string"
    },
    "baseline_timeline_ref": {
      "minLength": 1,
      "title": "Baseline Timeline Ref",
      "type": "string"
    },
    "canonical_edit_points_moved": {
      "default": false,
      "title": "Canonical Edit Points Moved",
      "type": "boolean"
    },
    "canonical_timeline_mutated": {
      "default": true,
      "title": "Canonical Timeline Mutated",
      "type": "boolean"
    },
    "changed_segment_count": {
      "minimum": 0,
      "title": "Changed Segment Count",
      "type": "integer"
    },
    "commands_executed": {
      "default": false,
      "title": "Commands Executed",
      "type": "boolean"
    },
    "current_duration_seconds": {
      "exclusiveMinimum": 0,
      "title": "Current Duration Seconds",
      "type": "number"
    },
    "duration_delta_seconds": {
      "title": "Duration Delta Seconds",
      "type": "number"
    },
    "image_generation_or_editing_used": {
      "default": false,
      "title": "Image Generation Or Editing Used",
      "type": "boolean"
    },
    "invalidated_steps": {
      "items": {
        "$ref": "#/$defs/RevisionPromotionInvalidation"
      },
      "title": "Invalidated Steps",
      "type": "array"
    },
    "media_rendered": {
      "default": false,
      "title": "Media Rendered",
      "type": "boolean"
    },
    "model_call_performed_by_cli": {
      "default": false,
      "title": "Model Call Performed By Cli",
      "type": "boolean"
    },
    "network_performed": {
      "default": false,
      "title": "Network Performed",
      "type": "boolean"
    },
    "next_commands": {
      "items": {
        "type": "string"
      },
      "title": "Next Commands",
      "type": "array"
    },
    "project_id": {
      "minLength": 1,
      "title": "Project Id",
      "type": "string"
    },
    "promoted_duration_seconds": {
      "exclusiveMinimum": 0,
      "title": "Promoted Duration Seconds",
      "type": "number"
    },
    "promoted_segment_count": {
      "minimum": 0,
      "title": "Promoted Segment Count",
      "type": "integer"
    },
    "promoted_timeline_fingerprint": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Promoted Timeline Fingerprint",
      "type": "string"
    },
    "promoted_timeline_id": {
      "minLength": 1,
      "title": "Promoted Timeline Id",
      "type": "string"
    },
    "promoted_timeline_ref": {
      "minLength": 1,
      "title": "Promoted Timeline Ref",
      "type": "string"
    },
    "revision_application_fingerprint": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Revision Application Fingerprint",
      "type": "string"
    },
    "revision_application_id": {
      "minLength": 1,
      "title": "Revision Application Id",
      "type": "string"
    },
    "revision_application_ref": {
      "minLength": 1,
      "title": "Revision Application Ref",
      "type": "string"
    },
    "revision_promotion_id": {
      "minLength": 1,
      "title": "Revision Promotion Id",
      "type": "string"
    },
    "schema_version": {
      "default": "0.3",
      "title": "Schema Version",
      "type": "string"
    },
    "segment_bindings": {
      "items": {
        "$ref": "#/$defs/RevisionPromotionSegmentBinding"
      },
      "title": "Segment Bindings",
      "type": "array"
    },
    "selected_version_id": {
      "minLength": 1,
      "title": "Selected Version Id",
      "type": "string"
    },
    "status": {
      "pattern": "^(promoted|warning|blocked)$",
      "title": "Status",
      "type": "string"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "revision_promotion_id",
    "project_id",
    "status",
    "revision_application_id",
    "revision_application_ref",
    "revision_application_fingerprint",
    "selected_version_id",
    "baseline_timeline_id",
    "baseline_timeline_ref",
    "baseline_timeline_fingerprint",
    "promoted_timeline_id",
    "promoted_timeline_ref",
    "promoted_timeline_fingerprint",
    "current_duration_seconds",
    "promoted_duration_seconds",
    "duration_delta_seconds",
    "baseline_segment_count",
    "promoted_segment_count",
    "changed_segment_count"
  ],
  "title": "RevisionPromotion",
  "type": "object"
}
