{
  "$defs": {
    "TextOptionPlan": {
      "additionalProperties": false,
      "properties": {
        "duration_seconds": {
          "exclusiveMinimum": 0,
          "title": "Duration Seconds",
          "type": "number"
        },
        "elements": {
          "items": {
            "$ref": "#/$defs/TextPlanElement"
          },
          "minItems": 1,
          "title": "Elements",
          "type": "array"
        },
        "emphasis_count": {
          "minimum": 0,
          "title": "Emphasis Count",
          "type": "integer"
        },
        "maximum_text_density_cps": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maximum Text Density Cps"
        },
        "option_id": {
          "enum": [
            "short",
            "standard",
            "extended"
          ],
          "title": "Option Id",
          "type": "string"
        },
        "pause_or_space_count": {
          "minimum": 0,
          "title": "Pause Or Space Count",
          "type": "integer"
        },
        "status": {
          "enum": [
            "ready",
            "degraded",
            "blocked"
          ],
          "title": "Status",
          "type": "string"
        },
        "subtitle_count": {
          "minimum": 0,
          "title": "Subtitle Count",
          "type": "integer"
        },
        "title_count": {
          "minimum": 0,
          "title": "Title Count",
          "type": "integer"
        },
        "unavailable_subtitle_slot_count": {
          "minimum": 0,
          "title": "Unavailable Subtitle Slot Count",
          "type": "integer"
        },
        "warnings": {
          "items": {
            "type": "string"
          },
          "title": "Warnings",
          "type": "array"
        }
      },
      "required": [
        "option_id",
        "duration_seconds",
        "elements",
        "title_count",
        "subtitle_count",
        "unavailable_subtitle_slot_count",
        "emphasis_count",
        "pause_or_space_count",
        "status"
      ],
      "title": "TextOptionPlan",
      "type": "object"
    },
    "TextPlanElement": {
      "additionalProperties": false,
      "properties": {
        "audio_pressure": {
          "enum": [
            "low",
            "medium",
            "high",
            "unknown"
          ],
          "title": "Audio Pressure",
          "type": "string"
        },
        "candidate_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Candidate Id"
        },
        "character_count": {
          "minimum": 0,
          "title": "Character Count",
          "type": "integer"
        },
        "characters_per_second": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Characters Per Second"
        },
        "content": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Content"
        },
        "element_id": {
          "title": "Element Id",
          "type": "string"
        },
        "element_type": {
          "enum": [
            "title",
            "subtitle",
            "emphasis",
            "pause",
            "empty_space"
          ],
          "title": "Element Type",
          "type": "string"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "evidence_status": {
          "enum": [
            "available",
            "partial",
            "unavailable",
            "not_applicable"
          ],
          "title": "Evidence Status",
          "type": "string"
        },
        "reading_risk": {
          "enum": [
            "none",
            "low",
            "medium",
            "high",
            "unavailable"
          ],
          "title": "Reading Risk",
          "type": "string"
        },
        "safe_region": {
          "enum": [
            "top",
            "center",
            "lower_third",
            "full_frame_reservation"
          ],
          "title": "Safe Region",
          "type": "string"
        },
        "safe_region_status": {
          "enum": [
            "reviewed_sample_only",
            "manual_review_required",
            "unavailable"
          ],
          "title": "Safe Region Status",
          "type": "string"
        },
        "source_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Id"
        },
        "source_in": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source In"
        },
        "source_out": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Out"
        },
        "timeline_in": {
          "minimum": 0,
          "title": "Timeline In",
          "type": "number"
        },
        "timeline_out": {
          "exclusiveMinimum": 0,
          "title": "Timeline Out",
          "type": "number"
        },
        "warnings": {
          "items": {
            "type": "string"
          },
          "title": "Warnings",
          "type": "array"
        }
      },
      "required": [
        "element_id",
        "element_type",
        "timeline_in",
        "timeline_out",
        "evidence_status",
        "character_count",
        "reading_risk",
        "safe_region",
        "safe_region_status",
        "audio_pressure"
      ],
      "title": "TextPlanElement",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "bgm_match_fingerprint": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Bgm Match Fingerprint",
      "type": "string"
    },
    "bgm_match_id": {
      "title": "Bgm Match Id",
      "type": "string"
    },
    "bgm_match_ref": {
      "title": "Bgm Match Ref",
      "type": "string"
    },
    "edit_brief_id": {
      "title": "Edit Brief Id",
      "type": "string"
    },
    "evidence_map_fingerprint": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Evidence Map Fingerprint",
      "type": "string"
    },
    "evidence_map_id": {
      "title": "Evidence Map Id",
      "type": "string"
    },
    "evidence_map_ref": {
      "title": "Evidence Map Ref",
      "type": "string"
    },
    "invented_lyrics": {
      "default": false,
      "title": "Invented Lyrics",
      "type": "boolean"
    },
    "invented_transcript": {
      "default": false,
      "title": "Invented Transcript",
      "type": "boolean"
    },
    "media_rendered": {
      "default": false,
      "title": "Media Rendered",
      "type": "boolean"
    },
    "model_call_performed_by_cli": {
      "default": false,
      "title": "Model Call Performed By Cli",
      "type": "boolean"
    },
    "network_performed": {
      "default": false,
      "title": "Network Performed",
      "type": "boolean"
    },
    "options": {
      "items": {
        "$ref": "#/$defs/TextOptionPlan"
      },
      "maxItems": 3,
      "minItems": 3,
      "title": "Options",
      "type": "array"
    },
    "project_id": {
      "title": "Project Id",
      "type": "string"
    },
    "schema_version": {
      "default": "0.3",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "enum": [
        "ready",
        "degraded",
        "blocked"
      ],
      "title": "Status",
      "type": "string"
    },
    "structure_fingerprint": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Structure Fingerprint",
      "type": "string"
    },
    "structure_recommendation_id": {
      "title": "Structure Recommendation Id",
      "type": "string"
    },
    "structure_ref": {
      "title": "Structure Ref",
      "type": "string"
    },
    "text_burned_into_media": {
      "default": false,
      "title": "Text Burned Into Media",
      "type": "boolean"
    },
    "text_plan_id": {
      "title": "Text Plan Id",
      "type": "string"
    },
    "timeline_mutated": {
      "default": false,
      "title": "Timeline Mutated",
      "type": "boolean"
    },
    "title_text": {
      "title": "Title Text",
      "type": "string"
    },
    "transcript_coverage_ratio": {
      "maximum": 1,
      "minimum": 0,
      "title": "Transcript Coverage Ratio",
      "type": "number"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "text_plan_id",
    "project_id",
    "structure_recommendation_id",
    "structure_ref",
    "structure_fingerprint",
    "evidence_map_id",
    "evidence_map_ref",
    "evidence_map_fingerprint",
    "bgm_match_id",
    "bgm_match_ref",
    "bgm_match_fingerprint",
    "edit_brief_id",
    "title_text",
    "options",
    "transcript_coverage_ratio",
    "status"
  ],
  "title": "TextTimingPlan",
  "type": "object"
}
