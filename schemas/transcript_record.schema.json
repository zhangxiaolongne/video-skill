{
  "$defs": {
    "EvidenceRef": {
      "additionalProperties": false,
      "properties": {
        "ref": {
          "minLength": 1,
          "title": "Ref",
          "type": "string"
        },
        "type": {
          "minLength": 1,
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "type",
        "ref"
      ],
      "title": "EvidenceRef",
      "type": "object"
    },
    "TranscriptRiskFlag": {
      "enum": [
        "low_confidence",
        "empty_text",
        "unclassified_text_type"
      ],
      "title": "TranscriptRiskFlag",
      "type": "string"
    },
    "TranscriptTextType": {
      "enum": [
        "interview",
        "role_dialogue",
        "lyrics",
        "stage_dialogue",
        "voice_over",
        "program_caption",
        "fan_caption"
      ],
      "title": "TranscriptTextType",
      "type": "string"
    },
    "WordTimestamp": {
      "additionalProperties": false,
      "properties": {
        "confidence": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Confidence"
        },
        "end_seconds": {
          "exclusiveMinimum": 0,
          "title": "End Seconds",
          "type": "number"
        },
        "start_seconds": {
          "minimum": 0,
          "title": "Start Seconds",
          "type": "number"
        },
        "word": {
          "minLength": 1,
          "title": "Word",
          "type": "string"
        }
      },
      "required": [
        "word",
        "start_seconds",
        "end_seconds"
      ],
      "title": "WordTimestamp",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "confidence": {
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Confidence",
      "type": "number"
    },
    "end_seconds": {
      "exclusiveMinimum": 0,
      "title": "End Seconds",
      "type": "number"
    },
    "evidence": {
      "items": {
        "$ref": "#/$defs/EvidenceRef"
      },
      "title": "Evidence",
      "type": "array"
    },
    "language": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Language"
    },
    "method": {
      "minLength": 1,
      "title": "Method",
      "type": "string"
    },
    "method_version": {
      "minLength": 1,
      "title": "Method Version",
      "type": "string"
    },
    "notes": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Notes"
    },
    "risk_flags": {
      "items": {
        "$ref": "#/$defs/TranscriptRiskFlag"
      },
      "title": "Risk Flags",
      "type": "array"
    },
    "schema_version": {
      "default": "0.3",
      "title": "Schema Version",
      "type": "string"
    },
    "segment_index": {
      "minimum": 0,
      "title": "Segment Index",
      "type": "integer"
    },
    "source_content_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Source Content Hash",
      "type": "string"
    },
    "source_fingerprint": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "title": "Source Fingerprint",
      "type": "string"
    },
    "source_id": {
      "minLength": 1,
      "title": "Source Id",
      "type": "string"
    },
    "source_location": {
      "minLength": 1,
      "title": "Source Location",
      "type": "string"
    },
    "speaker": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Speaker"
    },
    "start_seconds": {
      "minimum": 0,
      "title": "Start Seconds",
      "type": "number"
    },
    "text": {
      "title": "Text",
      "type": "string"
    },
    "text_type": {
      "anyOf": [
        {
          "$ref": "#/$defs/TranscriptTextType"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "transcript_id": {
      "minLength": 1,
      "title": "Transcript Id",
      "type": "string"
    },
    "user_confirmed": {
      "default": false,
      "title": "User Confirmed",
      "type": "boolean"
    },
    "word_timestamps": {
      "items": {
        "$ref": "#/$defs/WordTimestamp"
      },
      "title": "Word Timestamps",
      "type": "array"
    }
  },
  "required": [
    "transcript_id",
    "source_id",
    "source_location",
    "source_content_hash",
    "source_fingerprint",
    "segment_index",
    "start_seconds",
    "end_seconds",
    "text",
    "method",
    "method_version",
    "confidence"
  ],
  "title": "TranscriptRecord",
  "type": "object"
}
